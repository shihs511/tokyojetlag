  <script>
    // ─── TIME-BASED VIDEO SWITCHING ───
    // 東京の時間帯に応じて動画を自動切り替え（朝・昼・夜）
    // 手動で動画URLを差し替える場合は、以下のオブジェクトのURLを変更してください
    const VIDEO_SOURCES = {
      // 朝 (5:00-11:59 Tokyo time): Tokyo morning / sunrise footage
      morning: 'https://videos.pexels.com/video-files/4434242/4434242-sd_640_360_24fps.mp4',
      // 昼 (12:00-17:59 Tokyo time): Tokyo daytime city footage
      day: 'https://videos.pexels.com/video-files/2614602/2614602-sd_640_360_25fps.mp4',
      // 夜 (18:00-4:59 Tokyo time): Tokyo nightlife / neon footage
      night: 'https://videos.pexels.com/video-files/3942468/3942468-sd_640_360_30fps.mp4',
    };

    // Fallback static backgrounds per time of day
    const BG_FALLBACKS = {
      morning: 'https://images.unsplash.com/photo-1540959733332-eab4deabeeaf?w=1200&q=60',
      day: 'https://images.unsplash.com/photo-1503899036084-c55cdd92da26?w=1200&q=60',
      night: 'https://images.unsplash.com/photo-1542051841857-5f90071e7989?w=1200&q=60',
    };

    function getTokyoHour() {
      return parseInt(new Intl.DateTimeFormat('en-US', {
        hour: 'numeric', hour12: false, timeZone: 'Asia/Tokyo'
      }).format(new Date()));
    }

    function getTimeOfDay(hour) {
      if (hour >= 5 && hour < 12) return 'morning';
      if (hour >= 12 && hour < 18) return 'day';
      return 'night';
    }

    function loadTimeBasedVideo() {
      const tokyoHour = getTokyoHour();
      const tod = getTimeOfDay(tokyoHour);
      const video = document.getElementById('heroVideo');
      const imgBg = document.getElementById('heroImgBg');

      // Set static fallback immediately
      imgBg.style.backgroundImage = `url('${BG_FALLBACKS[tod]}')`;

      // Try to load video
      const src = VIDEO_SOURCES[tod];
      video.innerHTML = `<source src="${src}" type="video/mp4">`;
      video.load();

      video.addEventListener('canplaythrough', function onReady() {
        video.classList.add('loaded');
        imgBg.style.opacity = '0';
        video.removeEventListener('canplaythrough', onReady);
      }, { once: true });

      // If video fails, keep static bg
      video.addEventListener('error', function() {
        imgBg.style.opacity = '0.25';
      });

      // Check every 15 minutes if time of day changed
      setInterval(() => {
        const newTod = getTimeOfDay(getTokyoHour());
        if (newTod !== tod) location.reload();
      }, 15 * 60 * 1000);
    }

    loadTimeBasedVideo();

    // ─── VISITOR TIMEZONE ───
    (function() {
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
      const now = new Date();
      const fmtLocal = new Intl.DateTimeFormat('en-US', {
        hour: '2-digit', minute: '2-digit', hour12: true, timeZone: tz
      }).format(now);
      const fmtTokyo = new Intl.DateTimeFormat('en-US', {
        hour: '2-digit', minute: '2-digit', hour12: true, timeZone: 'Asia/Tokyo'
      }).format(now);
      const tokyoH = getTokyoHour();

      const tzCity = {
        'America/Los_Angeles': 'Los Angeles', 'America/New_York': 'New York',
        'America/Chicago': 'Chicago', 'America/Denver': 'Denver',
        'America/Vancouver': 'Vancouver', 'America/Toronto': 'Toronto',
        'Europe/London': 'London', 'Europe/Paris': 'Paris',
        'Europe/Berlin': 'Berlin', 'Europe/Rome': 'Rome',
        'Asia/Seoul': 'Seoul', 'Asia/Shanghai': 'Shanghai',
        'Asia/Singapore': 'Singapore', 'Asia/Bangkok': 'Bangkok',
        'Asia/Dubai': 'Dubai', 'Australia/Sydney': 'Sydney',
      };
      const city = tzCity[tz] || tz.split('/').pop().replace('_', ' ');

      const tokyoMsg = tokyoH >= 22 || tokyoH <= 5
        ? '🌙 Prime jet lag hours in Tokyo right now.'
        : tokyoH <= 8 ? '🌅 Early morning in Tokyo.'
        : '🗼 Tokyo is fully awake.';

      const el = document.getElementById('visitorClock');
      if (el) {
        el.innerHTML = `
          <span style="color:#7070a0">Your time (${city}):</span>
          <span style="color:#e8e8f0; font-weight:600"> ${fmtLocal}</span><br>
          <span style="color:#7070a0">Tokyo time:</span>
          <span style="color:#00f0ff; font-weight:600; text-shadow: 0 0 8px #00f0ff44;"> ${fmtTokyo}</span><br>
          <span style="color:#bf00ff; font-size:0.65rem;">${tokyoMsg}</span>
        `;
      }
    })();

    // ─── CANVAS: 窓点滅 + ネオン光 ───
    const canvas = document.getElementById('cityCanvas');
    const ctx = canvas.getContext('2d');

    function resizeCanvas() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    const windows = [];
    const WINDOW_COUNT = 100;
    const COLORS = ['#00f0ff', '#bf00ff', '#ff0080', '#ffe000', '#ffffff', '#ff6600'];

    for (let i = 0; i < WINDOW_COUNT; i++) {
      windows.push({
        x: Math.random(),
        y: 0.35 + Math.random() * 0.55,
        w: 2 + Math.random() * 5,
        h: 2 + Math.random() * 4,
        color: COLORS[Math.floor(Math.random() * COLORS.length)],
        alpha: Math.random(),
        speed: 0.002 + Math.random() * 0.015,
        phase: Math.random() * Math.PI * 2,
        offChance: Math.random() < 0.3,
        offTimer: 0,
        offDuration: 60 + Math.random() * 200,
      });
    }

    const streaks = [];
    const STREAK_COUNT = 6;
    for (let i = 0; i < STREAK_COUNT; i++) streaks.push(createStreak());

    function createStreak() {
      const isH = Math.random() < 0.4;
      return {
        x: Math.random(), y: 0.5 + Math.random() * 0.5,
        length: 0.05 + Math.random() * 0.15,
        speed: (0.001 + Math.random() * 0.003) * (Math.random() < 0.5 ? 1 : -1),
        color: COLORS[Math.floor(Math.random() * 3)],
        alpha: 0, fadeIn: true,
        maxAlpha: 0.3 + Math.random() * 0.5,
        fadeSpeed: 0.008 + Math.random() * 0.015,
        horizontal: isH, done: false,
      };
    }

    function drawFrame() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const W = canvas.width, H = canvas.height;

      windows.forEach(w => {
        if (w.offChance && w.offTimer > 0) { w.offTimer--; return; }
        if (w.offChance && Math.random() < 0.0005) { w.offTimer = w.offDuration; return; }
        w.phase += w.speed;
        const a = (Math.sin(w.phase) * 0.4 + 0.6) * 0.9;
        ctx.save();
        ctx.globalAlpha = a;
        ctx.fillStyle = w.color;
        ctx.shadowColor = w.color;
        ctx.shadowBlur = 4;
        ctx.fillRect(w.x * W, w.y * H, w.w, w.h);
        ctx.restore();
      });

      streaks.forEach((s, i) => {
        if (s.done) { streaks[i] = createStreak(); return; }
        if (s.fadeIn) { s.alpha += s.fadeSpeed; if (s.alpha >= s.maxAlpha) s.fadeIn = false; }
        else { s.alpha -= s.fadeSpeed * 0.5; if (s.alpha <= 0) { s.done = true; return; } }
        s.x += s.speed;
        if (s.x < -s.length || s.x > 1 + s.length) s.done = true;
        const x1 = s.x * W, y1 = s.y * H, len = s.length * W;
        ctx.save();
        ctx.globalAlpha = s.alpha;
        const grad = ctx.createLinearGradient(x1, y1, s.horizontal ? x1 + len : x1, s.horizontal ? y1 : y1 + len * 0.3);
        grad.addColorStop(0, 'transparent');
        grad.addColorStop(0.3, s.color);
        grad.addColorStop(0.7, s.color);
        grad.addColorStop(1, 'transparent');
        ctx.strokeStyle = grad;
        ctx.lineWidth = 1.5;
        ctx.shadowColor = s.color;
        ctx.shadowBlur = 8;
        ctx.beginPath();
        if (s.horizontal) { ctx.moveTo(x1, y1); ctx.lineTo(x1 + len, y1); }
        else { ctx.moveTo(x1, y1); ctx.lineTo(x1 + len * 0.1, y1 + len * 0.3); }
        ctx.stroke();
        ctx.restore();
      });

      requestAnimationFrame(drawFrame);
    }
    drawFrame();

    // ─── WORLD CLOCK ───
    function updateClocks() {
      const now = new Date();
      const fmt = tz => new Intl.DateTimeFormat('en-US', {
        hour: '2-digit', minute: '2-digit', hour12: false, timeZone: tz
      }).format(now);
      const hr = tz => parseInt(new Intl.DateTimeFormat('en-US', {
        hour: 'numeric', hour12: false, timeZone: tz
      }).format(now));

      const cities = [
        { id: 'tokyo',  tz: 'Asia/Tokyo' },
        { id: 'la',     tz: 'America/Los_Angeles' },
        { id: 'nyc',    tz: 'America/New_York' },
        { id: 'london', tz: 'Europe/London' },
      ];

      cities.forEach(c => {
        document.getElementById('time-' + c.id).textContent = fmt(c.tz);
        const h = hr(c.tz);
        const sleeping = h >= 23 || h < 6;
        const statusEl = document.getElementById('status-' + c.id);
        if (c.id === 'tokyo') {
          const jetlagged = h >= 1 && h <= 5;
          statusEl.textContent = jetlagged ? '🌙 Prime jet lag hours' : h >= 6 && h < 10 ? '🌅 Early morning' : '🗼 Normal hours';
          statusEl.className = 'clock-city-status status-awake';
        } else {
          statusEl.textContent = sleeping ? '😴 Probably asleep' : '☀️ Awake back home';
          statusEl.className = 'clock-city-status ' + (sleeping ? 'status-sleep' : 'status-awake');
        }
      });
    }
    updateClocks();
    setInterval(updateClocks, 30000);

    // ─── PARTICLES ───
    const particleContainer = document.getElementById('particles');
    for (let i = 0; i < 12; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.left = Math.random() * 100 + '%';
      p.style.animationDuration = (8 + Math.random() * 15) + 's';
      p.style.animationDelay = (Math.random() * 15) + 's';
      p.style.setProperty('--drift', (Math.random() * 100 - 50) + 'px');
      if (Math.random() > 0.5) p.style.background = '#bf00ff';
      if (Math.random() > 0.7) p.style.background = '#ff0080';
      particleContainer.appendChild(p);
    }

    // ─── AREA NAVIGATION ───
    function scrollToArea(area) {
      document.querySelectorAll('.area-btn').forEach(b => b.classList.remove('active'));
      event.target.classList.add('active');
      if (area === 'all') {
        document.getElementById('venues').scrollIntoView({ behavior: 'smooth' });
        document.querySelectorAll('.area-section').forEach(s => s.style.display = '');
      } else {
        document.querySelectorAll('.area-section').forEach(s => s.style.display = '');
        const target = document.getElementById('area-' + area);
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      }
    }

    // ─── TIME SLIDER ───
    const TIME_TIPS = {
      0:  [
        { icon: '🍜', title: 'Midnight Ramen', body: 'Ichiran is open 24h. Nagi in Golden Gai is still going. The best bowls happen after midnight.' },
        { icon: '🏮', title: 'Golden Gai', body: 'The tiny bars of Shinjuku are in full swing. Follow the noise down any alley.' },
        { icon: '🚕', title: 'Last Train Warning', body: 'Last trains left 30 min ago. Open the GO or S.RIDE app now, or settle in until 5AM.' },
      ],
      1:  [
        { icon: '🍜', title: 'Deep Night Ramen', body: 'Nagi Shinjuku open until 7AM. Ichiran 24h. Afuri Roppongi until 5AM.' },
        { icon: '🌃', title: 'Kabukicho Walk', body: 'The entertainment district never sleeps. Walk through for the spectacle.' },
        { icon: '🏧', title: 'Konbini Run', body: '7-Eleven has fresh onigiri. ATMs accept foreign cards. Coffee is always hot.' },
      ],
      2:  [
        { icon: '♨️', title: 'Thermae-Yu Onsen', body: 'Open 24h in Shinjuku. A hot spring soak at 2AM is deeply restorative.' },
        { icon: '🍜', title: "Ramen O'Clock", body: 'Peak ramen hour. Ichiran, Nagi, any open shop. You need this bowl.' },
        { icon: '🌆', title: 'Empty Shibuya', body: "Walk to Shibuya crossing. Weekends it's alive. Weekdays: eerily beautiful." },
      ],
      3:  [
        { icon: '🏙️', title: 'City of Ghosts', body: 'The streets are yours. Walk anywhere. The silence of Tokyo at 3AM is extraordinary.' },
        { icon: '♨️', title: 'Night Onsen', body: "Thermae-Yu still open. You'll have the rotenburo almost to yourself." },
        { icon: '☕', title: 'Konbini Coffee', body: 'All convenience stores have freshly brewed coffee. ¥100. Surprisingly good.' },
      ],
      4:  [
        { icon: '🚚', title: 'City Wakes Up', body: "Delivery trucks appear. Tsukiji outer market vendors start setup. Tokyo's other shift begins." },
        { icon: '🌅', title: 'Pre-Dawn Walk', body: 'Head toward any park. The light before sunrise in Tokyo is unlike anywhere else.' },
        { icon: '🍱', title: 'Early Breakfast', body: 'Some teishoku restaurants open at 5AM. Look for the ones with handwritten signs.' },
      ],
      5:  [
        { icon: '🌅', title: 'Sunrise Time', body: 'Ueno Park, Shinjuku Gyoen, Yoyogi. Any open green space will reward you now.' },
        { icon: '⛩️', title: 'Meiji Shrine', body: 'Enter the forest before anyone else arrives. The morning rituals begin at dawn.' },
        { icon: '🚃', title: 'First Trains', body: 'Yamanote Line restarts around 5AM. You can go anywhere again. The city resets.' },
      ],
      6:  [
        { icon: '🍳', title: 'Morning Set', body: 'Breakfast sets (モーニング) at kissaten coffee shops. Toast, egg, coffee for ¥500.' },
        { icon: '🏯', title: 'Beat the Crowds', body: 'Senso-ji, Meiji Shrine, any temple. You have 2 hours before tour groups arrive.' },
        { icon: '🐟', title: 'Tsukiji Outer Market', body: 'Breakfast sushi and tamagoyaki at the outer market stalls. Open from 5-6AM.' },
      ],
      7:  [
        { icon: '☕', title: 'Coffee Culture', body: "Kissaten old-school coffee shops are at their best at 7AM. Order the morning set." },
        { icon: '🌸', title: 'Park Walking', body: 'Tokyo parks are gorgeous in morning light. Locals exercise, feed birds, read.' },
        { icon: '🛍️', title: 'Early Konbini', body: 'Fresh deliveries just arrived. Best onigiri selection of the day is right now.' },
      ],
      8:  [
        { icon: '🚇', title: 'Rush Hour', body: 'Trains are packed. Avoid the subway 8-9AM if possible. Walk instead.' },
        { icon: '🍱', title: 'Breakfast Done Right', body: 'Hotel breakfast or a neighborhood kissaten. Set yourself up for the day.' },
        { icon: '🗺️', title: 'Morning Museums', body: 'National museums open at 9AM. First hour is almost empty.' },
      ],
      9:  [
        { icon: '🏛️', title: 'Museums Open', body: 'Tokyo National Museum, teamLab, Mori Art Museum. Pick one, go early.' },
        { icon: '🛒', title: 'Department Stores', body: 'Depachika (basement food halls) open at 10AM. Worth a visit just to look.' },
        { icon: '🌿', title: 'Garden Time', body: 'Shinjuku Gyoen, Hamarikyu. Morning in a Japanese garden.' },
      ],
      10: [
        { icon: '🏙️', title: 'City in Full Swing', body: 'Everything is open. The most normal hour of the Tokyo day.' },
        { icon: '🍣', title: 'Sushi Breakfast', body: 'Tsukiji outer market is still going. Toyosu market has tours and sushi.' },
        { icon: '📸', title: 'Photography Hour', body: 'Morning light in Yanaka, Shimokitazawa, or Koenji.' },
      ],
      11: [
        { icon: '🍱', title: 'Pre-Lunch Window', body: 'Best ramen shops open at 11AM and run out by early afternoon. Go now.' },
        { icon: '🛍️', title: 'Harajuku / Omotesando', body: 'Shops open, crowds manageable. Fashion district before afternoon rush.' },
        { icon: '🏯', title: 'Last Quiet Temple Hour', body: 'By noon, tour groups arrive. Visit Asakusa now for breathing room.' },
      ],
      12: [
        { icon: '🍜', title: 'Lunch Rush', body: 'Every ramen shop has a line. Avoid peak noon, eat at 11:30 or 1:30.' },
        { icon: '🌳', title: 'Midday Park Break', body: 'Salary workers eat in parks. Join them. Konbini lunch outside.' },
        { icon: '☕', title: 'Afternoon Coffee', body: "Blue Bottle, Sarutahiko, Onibus — Tokyo's specialty coffee is excellent." },
      ],
      13: [
        { icon: '🎌', title: 'Afternoon Temples', body: 'Crowds thin slightly after lunch. Good time for a second temple visit.' },
        { icon: '🎮', title: 'Akihabara', body: 'Electronics and anime district is fully alive in the afternoon.' },
        { icon: '🍦', title: 'Soft Serve Tour', body: 'Matcha in Asakusa, sesame in Yanaka, wagyu in Ginza.' },
      ],
      14: [
        { icon: '🏬', title: 'Shibuya Scramble', body: 'Afternoon is good for Shibuya. Crowds manageable, shops open.' },
        { icon: '🎨', title: 'Art Galleries', body: 'Mori Art Museum, 21_21 Design Sight, or Ginza galleries.' },
        { icon: '🏮', title: 'Planning Dinner', body: "Figure out where you're eating tonight. Popular places fill by 7PM." },
      ],
      15: [
        { icon: '🌅', title: 'Golden Hour Prep', body: 'Position somewhere high or scenic before 5PM. Skytree, Roppongi Hills.' },
        { icon: '🍵', title: 'Afternoon Tea', body: 'Hotel lobby bars and tea rooms are at their best mid-afternoon.' },
        { icon: '🛒', title: 'Depachika Peak', body: 'Basement food halls fully stocked. Best selection of the day.' },
      ],
      16: [
        { icon: '🌆', title: 'Golden Hour', body: 'Get to any elevated spot. Tokyo Tower, Skytree, or a rooftop terrace.' },
        { icon: '🍺', title: 'Happy Hour Starts', body: 'Standing bars (tachinomi) and izakayas start early deals. Beer from ¥300.' },
        { icon: '🚶', title: 'Evening Walk', body: 'Daikanyama, Nakameguro canal, or Shimokitazawa. Best in early evening.' },
      ],
      17: [
        { icon: '🌅', title: 'Sunset Tokyo', body: 'Find the canal at Nakameguro or a shrine gate silhouette. Pure Tokyo.' },
        { icon: '🍺', title: 'After-Work Drinks', body: 'Salary workers descend on izakayas. Join the energy. Standing bar near any station.' },
        { icon: '🍣', title: 'Pre-Dinner Sushi', body: 'Conveyor belt sushi before the dinner rush. Cheaper and still excellent.' },
      ],
      18: [
        { icon: '🍖', title: 'Dinner Time', body: 'Yakitori under the train tracks, kushikatsu in a basement, or kaiseki if planned.' },
        { icon: '🏮', title: 'Shinjuku Neon Wakes', body: 'Neon signs of Shinjuku fully illuminate after dark. Walk east from station.' },
        { icon: '🎭', title: 'Evening Entertainment', body: "Kabuki, live music, standing comedy. Check what's on." },
      ],
      19: [
        { icon: '🍺', title: 'Izakaya Prime Time', body: 'Best hour at any izakaya. Groups are lively, food flowing, beer cold.' },
        { icon: '🌃', title: 'Night Photography', body: 'Tokyo after dark is one of the most photogenic cities on earth.' },
        { icon: '🎶', title: 'Live Music', body: 'Shimokitazawa live houses. Shows typically start at 7-8PM.' },
      ],
      20: [
        { icon: '🍶', title: 'Whisky Bar Time', body: "Japan's whisky culture shines in small bars. Try any quiet counter." },
        { icon: '🌆', title: 'Night View', body: 'Tokyo at night from above. Skytree, observation decks, any tall building.' },
        { icon: '🎰', title: 'Pachinko Curiosity', body: 'Experience the sensory overload of a pachinko parlor. Uniquely Japanese.' },
      ],
      21: [
        { icon: '🍜', title: 'Ramen for Dinner', body: 'Lines have calmed. Evening ramen at a proper shop before midnight rush.' },
        { icon: '🏮', title: 'Golden Gai Warms Up', body: 'Tiny bars filling up. Good time to find your spot for the night.' },
        { icon: '🚃', title: 'Train Window', body: 'Take any JR line for a few stops at night. The city from the train is cinema.' },
      ],
      22: [
        { icon: '🍸', title: 'Bar Hopping Hour', body: 'Shinjuku, Roppongi, Shibuya or Shimokitazawa depending on energy.' },
        { icon: '⏰', title: 'Last Train Awareness', body: 'Last trains leave around midnight. Have GO or S.RIDE ready.' },
        { icon: '🌃', title: 'Night Walk', body: 'The city is at its most cinematic 10PM–midnight. Just walk.' },
      ],
      23: [
        { icon: '🕛', title: 'Last Train Decision', body: "In the next hour: taxi home (open GO app) or stay until 5AM. Commit." },
        { icon: '🍜', title: 'Midnight Ramen Pre-Load', body: "Eat ramen now before the midnight rush. You'll be glad you did." },
        { icon: '🏮', title: 'Night Owls Gathering', body: "The people left out at midnight chose to be here. The nocturnal crowd emerges." },
      ],
    };

    function renderTimeTips(hour) {
      const h = parseInt(hour);
      const tips = TIME_TIPS[h] || TIME_TIPS[0];
      const pad = h => String(h).padStart(2,'0');
      document.getElementById('sliderTimeDisplay').textContent = `${pad(h)}:00`;

      const container = document.getElementById('timeTipCards');
      container.innerHTML = tips.map(t => `
        <div class="tip-card">
          <div class="tip-card-icon">${t.icon}</div>
          <div class="tip-card-title">${t.title}</div>
          <div class="tip-card-body">${t.body}</div>
        </div>
      `).join('');
    }

    function setTokyoNow() {
      const h = getTokyoHour();
      document.getElementById('timeSlider').value = h;
      renderTimeTips(h);
    }

    document.getElementById('timeSlider').addEventListener('input', e => {
      renderTimeTips(e.target.value);
    });

    setTokyoNow();
  </script>
</body>
</html>
