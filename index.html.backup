  <!-- DNS prefetch for external resources -->
  <!-- Favicon: Tokyo Tower -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='0' y2='1'%3E%3Cstop offset='0%25' stop-color='%23ff0080'/%3E%3Cstop offset='100%25' stop-color='%23ff4400'/%3E%3C/linearGradient%3E%3C/defs%3E%3Cpath d='M32 2 L26 38 L22 62 L28 62 L29 46 L35 46 L36 62 L42 62 L38 38 Z' fill='url(%23g)'/%3E%3Crect x='24' y='20' width='16' height='3' rx='1' fill='%23fff' opacity='0.9'/%3E%3Crect x='25' y='28' width='14' height='3' rx='1' fill='%23fff' opacity='0.7'/%3E%3Crect x='26' y='36' width='12' height='2' rx='1' fill='%23fff' opacity='0.5'/%3E%3Ccircle cx='32' cy='10' r='2.5' fill='%2300f0ff'/%3E%3Cline x1='32' y1='2' x2='32' y2='7' stroke='%2300f0ff' stroke-width='1.5'/%3E%3C/svg%3E" />
  <link rel="dns-prefetch" href="https://images.unsplash.com" />
  <link rel="dns-prefetch" href="https://maps.google.com" />
  <link rel="dns-prefetch" href="https://videos.pexels.com" />

  <!-- Preload critical hero background -->
  <link rel="preload" as="image" href="https://images.unsplash.com/photo-1542051841857-5f90071e7989?w=1200&q=60" fetchpriority="high" />

  <!-- Fonts: preconnect + optimized loading -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&family=Noto+Sans+JP:wght@300;400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --neon-blue: #00f0ff;
      --neon-purple: #bf00ff;
      --neon-pink: #ff0080;
      --neon-yellow: #ffe000;
      --neon-green: #00ff88;
      --bg-dark: #04040f;
      --bg-card: #0a0a1e;
      --bg-card-hover: #0f0f2a;
      --text-main: #e8e8f0;
      --text-dim: #7070a0;
      --text-bright: #ffffff;
      --glow-blue: 0 0 6px #00f0ff88, 0 0 12px #00f0ff22;
      --glow-purple: 0 0 6px #bf00ff88, 0 0 12px #bf00ff22;
      --glow-pink: 0 0 6px #ff008088, 0 0 12px #ff008022;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    /* ─── SKIP TO CONTENT ─── */
    .skip-to-content {
      position: absolute;
      top: -100%;
      left: 50%;
      transform: translateX(-50%);
      background: var(--neon-blue);
      color: var(--bg-dark);
      padding: 0.8rem 1.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      z-index: 200;
      border-radius: 0 0 6px 6px;
      text-decoration: none;
      transition: top 0.2s;
    }
    .skip-to-content:focus {
      top: 0;
      outline: 2px solid var(--neon-pink);
      outline-offset: 2px;
    }

    /* ─── FOCUS STYLES ─── */
    :focus-visible {
      outline: 2px solid var(--neon-blue);
      outline-offset: 2px;
    }
    a:focus-visible, button:focus-visible {
      outline: 2px solid var(--neon-blue);
      outline-offset: 2px;
    }

    body {
      background: var(--bg-dark);
      color: var(--text-main);
      font-family: 'Inter', 'Space Mono', sans-serif;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* Scanline overlay */
    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(0,0,0,0.02) 3px,
        rgba(0,0,0,0.02) 6px
      );
      pointer-events: none;
      z-index: 100;
    }

    /* ─── HEADER ─── */
    header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 50;
      padding: 1rem 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(0, 240, 255, 0.08);
      background: rgba(4, 4, 15, 0.9);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }

    .logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 0.1em;
      color: var(--neon-blue);
      text-shadow: var(--glow-blue);
      text-decoration: none;
    }
    .logo span { color: var(--neon-pink); text-shadow: var(--glow-pink); }

    nav { display: flex; gap: 0.5rem; }
    nav a {
      color: var(--text-dim);
      text-decoration: none;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.4rem 0.8rem;
      border-radius: 4px;
      transition: all 0.2s;
      font-family: 'Space Mono', monospace;
    }
    nav a:hover {
      color: var(--neon-blue);
      background: rgba(0,240,255,0.06);
    }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 8rem 2.5rem 4rem;
      position: relative;
      overflow: hidden;
    }

    .hero::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--neon-blue), var(--neon-purple), var(--neon-pink), transparent);
      box-shadow: 0 0 15px var(--neon-blue), 0 0 30px var(--neon-purple);
      opacity: 0.5;
    }

    .grid-bg {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,240,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,240,255,0.02) 1px, transparent 1px);
      background-size: 60px 60px;
      animation: grid-scroll 20s linear infinite;
    }
    @keyframes grid-scroll {
      0% { transform: perspective(500px) rotateX(30deg) translateY(0); }
      100% { transform: perspective(500px) rotateX(30deg) translateY(60px); }
    }

    .particles {
      position: absolute;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
    }
    .particle {
      position: absolute;
      width: 2px; height: 2px;
      background: var(--neon-blue);
      border-radius: 50%;
      animation: float-up linear infinite;
      opacity: 0;
    }
    @keyframes float-up {
      0% { transform: translateY(100vh) translateX(0); opacity: 0; }
      10% { opacity: 0.8; }
      90% { opacity: 0.3; }
      100% { transform: translateY(-10vh) translateX(var(--drift)); opacity: 0; }
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 900px;
    }

    .clock-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      border: 1px solid rgba(0, 240, 255, 0.3);
      padding: 0.4rem 1rem;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--neon-blue);
      margin-bottom: 2rem;
      animation: pulse-border 3s ease-in-out infinite;
      font-family: 'Space Mono', monospace;
      border-radius: 2px;
    }
    @keyframes pulse-border {
      0%, 100% { border-color: rgba(0,240,255,0.3); box-shadow: 0 0 8px rgba(0,240,255,0.1); }
      50% { border-color: rgba(191,0,255,0.4); box-shadow: 0 0 8px rgba(191,0,255,0.15); }
    }
    .clock-dot {
      width: 6px; height: 6px;
      background: var(--neon-blue);
      border-radius: 50%;
      animation: blink 1s step-end infinite;
      box-shadow: var(--glow-blue);
    }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

    h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4rem, 12vw, 10rem);
      line-height: 0.9;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }
    .h1-line1 { color: var(--text-main); display: block; }
    .h1-line2 {
      color: var(--neon-blue);
      text-shadow: var(--glow-blue);
      display: block;
      animation: flicker 8s ease-in-out infinite;
    }
    .h1-line3 {
      color: var(--neon-pink);
      text-shadow: var(--glow-pink);
      display: block;
      font-size: clamp(2rem, 6vw, 5rem);
    }
    @keyframes flicker {
      0%, 95%, 100% { opacity: 1; text-shadow: var(--glow-blue); }
      96% { opacity: 0.8; text-shadow: none; }
      97% { opacity: 1; text-shadow: var(--glow-blue); }
      98% { opacity: 0.6; text-shadow: none; }
      99% { opacity: 1; text-shadow: var(--glow-blue); }
    }

    .hero-sub {
      margin-top: 2rem;
      font-size: 0.85rem;
      line-height: 1.8;
      color: var(--text-dim);
      max-width: 500px;
      border-left: 2px solid var(--neon-purple);
      padding-left: 1rem;
    }

    .world-clock {
      margin-top: 3rem;
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .clock-city { display: flex; flex-direction: column; gap: 0.2rem; }
    .clock-city-name {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: var(--text-dim);
      text-transform: uppercase;
      font-family: 'Space Mono', monospace;
    }
    .clock-city-time {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 0.05em;
      line-height: 1;
    }
    .clock-city-time.tokyo { color: var(--neon-blue); text-shadow: var(--glow-blue); }
    .clock-city-time.la { color: var(--neon-purple); text-shadow: var(--glow-purple); }
    .clock-city-time.nyc { color: var(--neon-pink); text-shadow: var(--glow-pink); }
    .clock-city-time.london { color: var(--neon-yellow); text-shadow: 0 0 8px var(--neon-yellow); }
    .clock-city-status { font-size: 0.65rem; letter-spacing: 0.1em; font-family: 'Space Mono', monospace; }
    .status-awake { color: #ff4444; }
    .status-sleep { color: #44ff88; }

    /* ─── VIDEO BACKGROUND ─── */
    .hero-video {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      opacity: 0;
      z-index: 0;
      pointer-events: none;
      filter: saturate(0.5) brightness(0.6);
      transition: opacity 1.5s ease;
    }
    .hero-video.loaded { opacity: 0.35; }
    .hero-video-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(4,4,15,0.6) 0%,
        rgba(4,4,15,0.15) 30%,
        rgba(4,4,15,0.4) 70%,
        rgba(4,4,15,1) 100%
      );
      z-index: 0;
      pointer-events: none;
    }
    .hero-img-bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      opacity: 0.2;
      z-index: 0;
      pointer-events: none;
      transition: opacity 1.5s ease;
    }

    /* ─── SECTION COMMON ─── */
    section {
      padding: 6rem 2.5rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--neon-purple);
      text-shadow: var(--glow-purple);
      margin-bottom: 0.8rem;
      font-family: 'Space Mono', monospace;
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      line-height: 1;
      margin-bottom: 1.5rem;
      color: var(--text-main);
    }
    .section-title span { color: var(--neon-blue); text-shadow: var(--glow-blue); }

    .section-desc {
      font-size: 0.85rem;
      color: var(--text-dim);
      line-height: 1.8;
      max-width: 600px;
      margin-bottom: 3rem;
    }

    /* ─── JET LAG EXPLAINER ─── */
    .jetlag-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(0,240,255,0.08);
      border: 1px solid rgba(0,240,255,0.08);
      border-radius: 4px;
      overflow: hidden;
    }
    @media (max-width: 900px) { .jetlag-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 500px) { .jetlag-grid { grid-template-columns: 1fr; } }
    .jetlag-card {
      background: var(--bg-card);
      padding: 2.5rem;
      position: relative;
      overflow: hidden;
      transition: background 0.3s;
    }
    .jetlag-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px; height: 0;
      background: var(--neon-blue);
      transition: height 0.4s ease;
    }
    .jetlag-card:hover { background: var(--bg-card-hover); }
    .jetlag-card:hover::before { height: 100%; }
    .jetlag-time {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3.5rem;
      color: var(--neon-blue);
      text-shadow: var(--glow-blue);
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .jetlag-from {
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      color: var(--text-dim);
      margin-bottom: 1rem;
      text-transform: uppercase;
      font-family: 'Space Mono', monospace;
    }
    .jetlag-feeling {
      font-size: 0.82rem;
      color: var(--text-main);
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }
    .jetlag-action {
      font-size: 0.65rem;
      color: var(--neon-pink);
      text-shadow: var(--glow-pink);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-family: 'Space Mono', monospace;
    }

    /* ─── AREA NAVIGATION ─── */
    .area-nav {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 3rem;
      padding: 1rem 0;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
      scrollbar-color: rgba(0,240,255,0.2) transparent;
      scroll-snap-type: x proximity;
    }
    .area-nav::-webkit-scrollbar { height: 3px; }
    .area-nav::-webkit-scrollbar-track { background: transparent; }
    .area-nav::-webkit-scrollbar-thumb { background: rgba(0,240,255,0.2); border-radius: 3px; }
    .area-btn {
      background: transparent;
      border: 1px solid rgba(0,240,255,0.15);
      color: var(--text-dim);
      padding: 0.6rem 1.2rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.25s;
      border-radius: 3px;
      white-space: nowrap;
      min-height: 44px;
      min-width: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      scroll-snap-align: start;
      flex-shrink: 0;
    }
    .area-btn:hover, .area-btn.active {
      border-color: var(--neon-blue);
      color: var(--neon-blue);
      box-shadow: var(--glow-blue);
      background: rgba(0,240,255,0.06);
    }

    /* ─── VENUE AREA SECTIONS ─── */
    .area-section {
      margin-bottom: 4rem;
      scroll-margin-top: 120px;
    }
    .area-header {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(0,240,255,0.08);
    }
    .area-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.5rem;
      color: var(--text-main);
      letter-spacing: 0.03em;
    }
    .area-name-jp {
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 1rem;
      color: var(--text-dim);
      font-weight: 300;
    }
    .area-desc {
      font-size: 0.78rem;
      color: var(--text-dim);
      line-height: 1.7;
      max-width: 700px;
      margin-bottom: 2rem;
    }

    /* ─── VENUES ─── */
    .venues-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    @media (max-width: 900px) { .venues-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .venues-grid { grid-template-columns: 1fr; } }

    .venue-card {
      background: var(--bg-card);
      border: 1px solid rgba(0,240,255,0.06);
      border-radius: 6px;
      overflow: hidden;
      cursor: pointer;
      transition: all 0.3s;
      position: relative;
    }
    .venue-card:hover {
      background: var(--bg-card-hover);
      border-color: rgba(0,240,255,0.15);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.3), 0 0 1px rgba(0,240,255,0.2);
    }

    .venue-img-wrap {
      position: relative;
      width: 100%;
      height: 180px;
      overflow: hidden;
    }
    .venue-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s, opacity 0.3s;
      opacity: 0.85;
    }
    .venue-card:hover .venue-img {
      transform: scale(1.05);
      opacity: 1;
    }
    .venue-img-overlay {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 60%;
      background: linear-gradient(transparent, rgba(10,10,30,0.9));
      pointer-events: none;
    }

    .venue-content { padding: 1.2rem 1.5rem 1.5rem; }

    .venue-tag {
      display: inline-block;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.25rem 0.6rem;
      margin-bottom: 0.8rem;
      border-radius: 2px;
      font-family: 'Space Mono', monospace;
    }
    .tag-ramen { background: rgba(255,0,128,0.08); color: var(--neon-pink); border: 1px solid rgba(255,0,128,0.25); }
    .tag-bar { background: rgba(0,240,255,0.08); color: var(--neon-blue); border: 1px solid rgba(0,240,255,0.25); }
    .tag-izakaya { background: rgba(255,224,0,0.08); color: var(--neon-yellow); border: 1px solid rgba(255,224,0,0.25); }
    .tag-24h { background: rgba(191,0,255,0.08); color: var(--neon-purple); border: 1px solid rgba(191,0,255,0.25); }
    .tag-walk { background: rgba(0,255,136,0.08); color: var(--neon-green); border: 1px solid rgba(0,255,136,0.25); }
    .tag-onsen { background: rgba(0,240,255,0.08); color: #00ffcc; border: 1px solid rgba(0,255,200,0.25); }
    .tag-cafe { background: rgba(255,160,0,0.08); color: #ffa040; border: 1px solid rgba(255,160,0,0.25); }
    .tag-sushi { background: rgba(255,0,128,0.08); color: #ff6090; border: 1px solid rgba(255,0,128,0.2); }
    .tag-club { background: rgba(191,0,255,0.08); color: #d060ff; border: 1px solid rgba(191,0,255,0.2); }

    .venue-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 0.04em;
      color: var(--text-bright);
      margin-bottom: 0.2rem;
      line-height: 1.1;
    }
    .venue-name-jp {
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 0.72rem;
      color: var(--text-dim);
      margin-bottom: 0.8rem;
      font-weight: 300;
    }
    .venue-hours {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.65rem;
      color: var(--neon-blue);
      margin-bottom: 0.6rem;
      font-family: 'Space Mono', monospace;
    }
    .venue-hours::before {
      content: '●';
      color: var(--neon-green);
      font-size: 0.45rem;
      animation: blink 2s step-end infinite;
    }
    .venue-desc {
      font-size: 0.75rem;
      color: var(--text-dim);
      line-height: 1.7;
      margin-bottom: 0.8rem;
    }
    .venue-verify {
      font-size: 0.65rem;
      color: rgba(255,160,0,0.8);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-family: 'Space Mono', monospace;
    }
    .venue-verify::before { content: '⚠ '; }
    .venue-map-link {
      display: inline-flex;
      align-items: center;
      margin-top: 0.6rem;
      font-size: 0.68rem;
      color: var(--neon-blue);
      text-decoration: none;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-bottom: 1px solid rgba(0,240,255,0.2);
      padding: 0.4rem 0;
      min-height: 44px;
      transition: all 0.2s;
      font-family: 'Space Mono', monospace;
    }
    .venue-map-link:hover, .venue-map-link:focus-visible {
      color: var(--neon-pink);
      border-color: var(--neon-pink);
    }

    /* ─── SURVIVAL TIPS ─── */
    .tips-section {
      background: #060614;
      border-top: 1px solid rgba(0,240,255,0.06);
      border-bottom: 1px solid rgba(0,240,255,0.06);
    }
    .tips-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
    @media (max-width: 900px) { .tips-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .tips-grid { grid-template-columns: 1fr; } }
    .tip-item { display: flex; flex-direction: column; gap: 0.8rem; }
    .tip-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3.5rem;
      color: rgba(0,240,255,0.1);
      line-height: 1;
    }
    .tip-title {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text-main);
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }
    .tip-body {
      font-size: 0.75rem;
      color: var(--text-dim);
      line-height: 1.8;
    }

    /* ─── TAXI SECTION ─── */
    .taxi-section {
      background: #060614;
      border-top: 1px solid rgba(0,240,255,0.06);
      border-bottom: 1px solid rgba(0,240,255,0.06);
      padding: 5rem 2.5rem;
    }
    .taxi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      max-width: 1200px;
      margin: 0 auto;
    }
    @media (max-width: 900px) { .taxi-grid { grid-template-columns: 1fr; } }
    .taxi-card {
      background: var(--bg-card);
      border: 1px solid rgba(0,240,255,0.08);
      padding: 2rem;
      border-top: 3px solid var(--neon-blue);
      transition: all 0.3s;
      border-radius: 6px;
    }
    .taxi-card:hover { border-top-color: var(--neon-pink); transform: translateY(-2px); }
    .taxi-card-icon {
      width: 56px; height: 56px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 1.2rem;
      color: #fff;
    }
    .taxi-card-icon.icon-go { background: linear-gradient(135deg, #00c853, #00897b); box-shadow: 0 0 12px rgba(0,200,83,0.3); }
    .taxi-card-icon.icon-sride { background: linear-gradient(135deg, #1a237e, #4a148c); box-shadow: 0 0 12px rgba(74,20,156,0.3); }
    .taxi-card-icon.icon-uber { background: linear-gradient(135deg, #111, #333); box-shadow: 0 0 12px rgba(255,255,255,0.1); }
    .taxi-card-rank {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--neon-blue);
      margin-bottom: 0.6rem;
    }
    .taxi-card-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      letter-spacing: 0.05em;
      color: var(--text-main);
      margin-bottom: 0.5rem;
    }
    .taxi-card-tagline {
      font-size: 0.72rem;
      color: var(--neon-pink);
      margin-bottom: 1.2rem;
    }
    .taxi-card-body {
      font-size: 0.73rem;
      color: var(--text-dim);
      line-height: 1.8;
      margin-bottom: 1.5rem;
    }
    .taxi-card-links { display: flex; gap: 0.8rem; flex-wrap: wrap; }
    .taxi-card-links a {
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--neon-blue);
      text-decoration: none;
      border: 1px solid rgba(0,240,255,0.2);
      padding: 0.4rem 0.8rem;
      transition: all 0.2s;
      border-radius: 3px;
      font-family: 'Space Mono', monospace;
    }
    .taxi-card-links a:hover { background: rgba(0,240,255,0.1); color: var(--text-main); }
    .taxi-tip {
      max-width: 1200px;
      margin: 2rem auto 0;
      font-size: 0.68rem;
      color: var(--text-dim);
      line-height: 1.8;
      border: 1px solid rgba(0,240,255,0.06);
      padding: 1.5rem 2rem;
      background: rgba(0,240,255,0.02);
      border-radius: 6px;
    }
    .taxi-tip strong { color: var(--neon-blue); }

    /* ─── TIME SLIDER ─── */
    .time-slider-section {
      background: #060614;
      border-top: 1px solid rgba(0,240,255,0.06);
      padding: 5rem 2.5rem;
    }
    .time-slider-inner { max-width: 1200px; margin: 0 auto; }
    .slider-wrap { margin: 2rem 0 1rem; }
    .time-range {
      width: 100%;
      -webkit-appearance: none;
      appearance: none;
      height: 4px;
      background: rgba(0,240,255,0.2);
      outline: none;
      cursor: pointer;
      border-radius: 2px;
      border: none;
    }
    .time-range::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--neon-blue);
      box-shadow: var(--glow-blue);
      cursor: pointer;
      border: 2px solid var(--bg-dark);
    }
    .time-range::-moz-range-thumb {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--neon-blue);
      box-shadow: var(--glow-blue);
      cursor: pointer;
      border: 2px solid var(--bg-dark);
    }
    .time-range::-moz-range-track {
      height: 4px;
      background: rgba(0,240,255,0.2);
      border-radius: 2px;
      border: none;
    }
    .time-range:focus-visible::-webkit-slider-thumb {
      outline: 2px solid var(--neon-pink);
      outline-offset: 3px;
    }
    .slider-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 0.6rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      color: var(--text-dim);
    }
    .time-now-badge {
      display: inline-block;
      border: 1px solid rgba(0,240,255,0.3);
      color: var(--neon-blue);
      padding: 0.4rem 1rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      cursor: pointer;
      transition: all 0.2s;
      margin-bottom: 2rem;
      border-radius: 3px;
    }
    .time-now-badge:hover { background: rgba(0,240,255,0.08); box-shadow: var(--glow-blue); }
    .tip-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 1rem;
    }
    .tip-card {
      background: var(--bg-card);
      padding: 1.5rem;
      border-top: 2px solid rgba(0,240,255,0.15);
      border-radius: 0 0 6px 6px;
    }
    .tip-card-icon { font-size: 1.4rem; margin-bottom: 0.6rem; }
    .tip-card-title {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      color: var(--text-main);
      font-weight: 700;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }
    .tip-card-body {
      font-size: 0.68rem;
      color: var(--text-dim);
      line-height: 1.7;
    }
    @media (max-width: 700px) { .tip-cards { grid-template-columns: 1fr; } }

    /* ─── MAP ─── */
    .map-section {
      background: #060614;
      border-top: 1px solid rgba(0,240,255,0.06);
      padding: 5rem 2.5rem;
    }
    .map-inner { max-width: 1200px; margin: 0 auto; }
    .map-spots { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 1.5rem 0 0; }
    .map-spot-btn {
      background: transparent;
      border: 1px solid rgba(0,240,255,0.15);
      color: var(--text-dim);
      padding: 0.4rem 1rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.06em;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      display: inline-block;
      border-radius: 3px;
    }
    .map-spot-btn:hover {
      border-color: var(--neon-blue);
      color: var(--neon-blue);
      background: rgba(0,240,255,0.05);
    }
    .map-embed-wrap {
      position: relative;
      width: 100%;
      height: 480px;
      border: 1px solid rgba(0,240,255,0.1);
      overflow: hidden;
      margin-top: 2rem;
      border-radius: 6px;
    }
    .map-embed-wrap iframe {
      width: 100%; height: 100%;
      border: none;
      filter: invert(90%) hue-rotate(180deg) saturate(0.7);
      opacity: 0.9;
    }

    /* ─── FOOTER ─── */
    footer {
      padding: 4rem 2.5rem;
      border-top: 1px solid rgba(0,240,255,0.06);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
    }
    .footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      color: var(--neon-blue);
      text-shadow: var(--glow-blue);
    }
    .footer-sub {
      font-size: 0.65rem;
      color: var(--text-dim);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      line-height: 2;
      font-family: 'Space Mono', monospace;
    }
    .footer-disclaimer {
      font-size: 0.7rem;
      color: rgba(112,112,160,0.6);
      max-width: 500px;
      line-height: 1.8;
    }

    .neon-line {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--neon-blue), transparent);
      margin: 0;
      opacity: 0.12;
    }

    /* ─── CANVAS ─── */
    #cityCanvas {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      z-index: 1;
      pointer-events: none;
      opacity: 0.85;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 640px) {
      header { padding: 0.8rem 1rem; }
      nav { display: none; }
      .hero { padding: 6rem 1.2rem 3rem; }
      section { padding: 3rem 1.2rem; }

      .area-btn {
        padding: 0.5rem 1rem;
        font-size: 0.65rem;
        min-height: 44px;
      }
      .venues-grid { gap: 1rem; }
      .venue-img-wrap { height: 160px; }
      .world-clock { gap: 1.2rem; }
      .tip-cards { grid-template-columns: 1fr; }
      .taxi-grid { grid-template-columns: 1fr; }
      .taxi-section { padding: 3rem 1.2rem; }
      .time-slider-section { padding: 3rem 1.2rem; }
      .map-section { padding: 3rem 1.2rem; }
      .map-embed-wrap { height: 300px; }
      .slider-labels { font-size: 0.6rem; }
      .slider-labels span:nth-child(even) { display: none; }
      h1 { font-size: clamp(3rem, 10vw, 10rem); }
    }

    @media (max-width: 400px) {
      .world-clock { flex-direction: column; gap: 1rem; }
      .jetlag-grid { grid-template-columns: 1fr; }
    }

    /* Touch-friendly: ensure all interactive elements have adequate tap targets */
    @media (pointer: coarse) {
      nav a { min-height: 44px; display: inline-flex; align-items: center; }
      .map-spot-btn { min-height: 44px; display: inline-flex; align-items: center; }
      .taxi-card-links a { min-height: 44px; display: inline-flex; align-items: center; }
      .time-now-badge { min-height: 44px; display: inline-flex; align-items: center; }
    }

    /* Smooth scroll anchor offset */
    [id] { scroll-margin-top: 80px; }

    /* Reduced motion preference */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
      html { scroll-behavior: auto; }
      .hero-video { transition: none; }
      .grid-bg { animation: none; }
    }

    /* ─── MOBILE FONT MINIMUM ─── */
    @media (max-width: 640px) {
      .venue-desc, .venue-hours, .venue-verify, .area-desc,
      .tip-body, .taxi-card-body, .tip-card-body, .footer-disclaimer,
      .hero-sub, .section-desc {
        font-size: max(0.82rem, 13px);
      }
      .clock-city-name, .clock-city-status, .jetlag-from, .jetlag-action,
      .section-label, .taxi-card-rank, .venue-tag, .taxi-tip {
        font-size: max(0.7rem, 11px);
      }
      .venue-map-link, .taxi-card-links a, .map-spot-btn {
        font-size: max(0.72rem, 11.5px);
        min-height: 48px;
        padding: 0.5rem 1rem;
      }
      input[type="range"] { min-height: 44px; }
    }

    /* ─── CONTRAST IMPROVEMENTS ─── */
    .venue-verify { color: rgba(255,180,60,0.95); }
    .footer-disclaimer { color: rgba(140,140,180,0.8); }

    /* ─── AREA NAV SCROLL INDICATORS ─── */
    .area-nav-wrap {
      position: sticky;
      top: 60px;
      z-index: 10;
      background: rgba(4,4,15,0.95);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0,240,255,0.06);
    }
    .area-nav-wrap::before,
    .area-nav-wrap::after {
      content: '';
      position: absolute;
      top: 0; bottom: 0;
      width: 32px;
      z-index: 2;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .area-nav-wrap::before {
      left: 0;
      background: linear-gradient(90deg, rgba(4,4,15,0.95), transparent);
    }
    .area-nav-wrap::after {
      right: 0;
      background: linear-gradient(-90deg, rgba(4,4,15,0.95), transparent);
    }
    .area-nav-wrap.can-scroll-left::before { opacity: 1; }
    .area-nav-wrap.can-scroll-right::after { opacity: 1; }

    @media (max-width: 640px) {
      .area-nav-wrap {
        top: 50px;
        margin-left: -1.2rem;
        margin-right: -1.2rem;
        padding-left: 0;
        padding-right: 0;
      }
      .area-nav {
        padding-left: 1.2rem;
        padding-right: 1.2rem;
      }
    }

    /* ─── PRINT STYLES ─── */
    @media print {
      * { color: #000 !important; background: #fff !important; text-shadow: none !important; box-shadow: none !important; border-color: #ccc !important; }
      body::before, .grid-bg, .particles, .hero-video, .hero-video-overlay, .hero-img-bg,
      #cityCanvas, .neon-line, .skip-to-content, .area-nav-wrap, .map-embed-wrap,
      .time-slider-section, .clock-badge, .clock-dot { display: none !important; }
      header { position: static !important; background: #fff !important; backdrop-filter: none !important; border-bottom: 2px solid #000 !important; padding: 1rem !important; }
      .hero { min-height: auto !important; padding: 2rem 1rem !important; }
      section, .tips-section, .taxi-section { padding: 2rem 1rem !important; max-width: 100% !important; page-break-inside: avoid; }
      .venue-card { break-inside: avoid; border: 1px solid #ccc !important; margin-bottom: 1rem !important; }
      .venue-img-wrap { height: 120px !important; }
      .venue-img { filter: grayscale(0.5) !important; opacity: 1 !important; }
      .venues-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 1rem !important; }
      .jetlag-grid, .tips-grid, .taxi-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .venue-map-link::after { content: " (" attr(href) ")" !important; font-size: 0.6rem !important; word-break: break-all !important; }
      .logo, .logo span { color: #000 !important; }
      h1, h2, .section-title, .section-title span, .area-name, .venue-name { color: #000 !important; }
      footer { border-top: 2px solid #000 !important; }
      @page { margin: 2cm; }
    }

    /* ─── ENHANCED VENUE DETAILS ─── */
    .venue-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin: 0.6rem 0;
      font-size: 0.65rem;
      font-family: 'Space Mono', monospace;
    }
    .venue-meta-item {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.2rem 0.5rem;
      background: rgba(0,240,255,0.04);
      border: 1px solid rgba(0,240,255,0.08);
      border-radius: 3px;
      color: var(--text-dim);
    }
    .venue-meta-item .meta-icon { font-size: 0.7rem; }
    .venue-price { color: var(--neon-yellow); }
    .venue-station { color: var(--neon-green); }
    .venue-recommend {
      font-size: 0.72rem;
      color: var(--neon-pink);
      margin-top: 0.5rem;
      padding: 0.4rem 0.6rem;
      background: rgba(255,0,128,0.04);
      border-left: 2px solid rgba(255,0,128,0.3);
      line-height: 1.6;
    }
    .venue-recommend strong { color: var(--neon-blue); }

    /* ─── JET LAG TIPS SECTION ─── */
    .jetlag-tips-section {
      background: #060614;
      border-top: 1px solid rgba(0,240,255,0.06);
      border-bottom: 1px solid rgba(0,240,255,0.06);
      padding: 6rem 2.5rem;
    }
    .jetlag-tips-inner { max-width: 1200px; margin: 0 auto; }
    .jetlag-tips-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }
    @media (max-width: 700px) { .jetlag-tips-grid { grid-template-columns: 1fr; } }
    .jt-card {
      background: var(--bg-card);
      border: 1px solid rgba(0,240,255,0.08);
      border-radius: 6px;
      padding: 2rem;
      transition: all 0.3s;
    }
    .jt-card:hover { border-color: rgba(0,240,255,0.2); transform: translateY(-2px); }
    .jt-card-icon { font-size: 1.8rem; margin-bottom: 0.8rem; }
    .jt-card-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      color: var(--text-bright);
      letter-spacing: 0.04em;
      margin-bottom: 0.6rem;
    }
    .jt-card-body {
      font-size: 0.75rem;
      color: var(--text-dim);
      line-height: 1.8;
    }
    .jt-card-body strong { color: var(--neon-blue); }
    .jt-24h-badge {
      display: inline-block;
      background: rgba(191,0,255,0.1);
      color: var(--neon-purple);
      border: 1px solid rgba(191,0,255,0.3);
      padding: 0.15rem 0.5rem;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      font-family: 'Space Mono', monospace;
      border-radius: 2px;
      margin-left: 0.3rem;
    }

    /* ─── GETTING AROUND SECTION ─── */
    .getting-around-section {
      background: var(--bg-dark);
      padding: 6rem 2.5rem;
    }
    .getting-around-inner { max-width: 1200px; margin: 0 auto; }
    .ga-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }
    @media (max-width: 900px) { .ga-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .ga-grid { grid-template-columns: 1fr; } }
    .ga-card {
      background: var(--bg-card);
      border: 1px solid rgba(0,240,255,0.08);
      border-top: 3px solid var(--neon-purple);
      border-radius: 6px;
      padding: 2rem;
      transition: all 0.3s;
    }
    .ga-card:hover { border-top-color: var(--neon-blue); transform: translateY(-2px); }
    .ga-card-icon { font-size: 2rem; margin-bottom: 1rem; }
    .ga-card-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      color: var(--text-bright);
      letter-spacing: 0.04em;
      margin-bottom: 0.6rem;
    }
    .ga-card-body {
      font-size: 0.73rem;
      color: var(--text-dim);
      line-height: 1.8;
    }
    .ga-card-body strong { color: var(--neon-blue); }
    .ga-protip {
      max-width: 1200px;
      margin: 2rem auto 0;
      font-size: 0.72rem;
      color: var(--text-dim);
      line-height: 1.8;
      border: 1px solid rgba(191,0,255,0.15);
      padding: 1.5rem 2rem;
      background: rgba(191,0,255,0.03);
      border-radius: 6px;
    }
    .ga-protip strong { color: var(--neon-purple); }

    /* ─── ENHANCED FOOTER ─── */
    .footer-about {
      max-width: 600px;
      margin: 0 auto 2rem;
      text-align: center;
    }
    .footer-about-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      color: var(--text-main);
      margin-bottom: 0.8rem;
      letter-spacing: 0.05em;
    }
    .footer-about-text {
      font-size: 0.75rem;
      color: var(--text-dim);
      line-height: 1.8;
    }
    .footer-social {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin: 1.5rem 0;
    }
    .footer-social a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px; height: 40px;
      border: 1px solid rgba(0,240,255,0.15);
      border-radius: 50%;
      color: var(--text-dim);
      text-decoration: none;
      font-size: 1rem;
      transition: all 0.2s;
    }
    .footer-social a:hover {
      color: var(--neon-blue);
      border-color: var(--neon-blue);
      box-shadow: var(--glow-blue);
    }
    .footer-contact {
      font-size: 0.68rem;
      color: var(--text-dim);
      font-family: 'Space Mono', monospace;
      letter-spacing: 0.08em;
    }
    .footer-contact a {
      color: var(--neon-blue);
      text-decoration: none;
      border-bottom: 1px solid rgba(0,240,255,0.2);
    }
    .footer-contact a:hover { color: var(--neon-pink); border-color: var(--neon-pink); }

    /* Nav update for new sections */
    @media (max-width: 640px) {
      .jetlag-tips-section, .getting-around-section { padding: 3rem 1.2rem; }
    }
  </style>
</head>
<body>
  <a href="#venues" class="skip-to-content">Skip to venues</a>

  <!-- HEADER -->
  <header role="banner">
    <a href="#" class="logo" aria-label="Tokyo Jet Lag — Home">Tokyo<span>JetLag</span></a>
    <nav aria-label="Main navigation">
      <a href="#why">Why Awake</a>
      <a href="#venues">Venues</a>
      <a href="#jetlag-tips">Jet Lag Tips</a>
      <a href="#getting-around">Getting Around</a>
      <a href="#survive">Survive</a>
      <a href="#now">Right Now</a>
    </nav>
  </header>

  <!-- HERO -->
  <main>
  <div class="hero" role="region" aria-label="Hero section">
    <canvas id="cityCanvas"></canvas>

    <!--
      ★ TIME-BASED VIDEO BACKGROUND
      動画は東京の時間帯に応じて自動切り替え（朝・昼・夜）。
      Pexelsの無料動画を使用。読み込みに失敗した場合は静止画背景にフォールバック。

      手動で動画URLを差し替える場合は以下のIDを変更してください：
      - heroVideo: メインの<video>要素
      - JS内の VIDEO_SOURCES オブジェクト:
        morning: 朝の動画URL (5:00-11:59 Tokyo time)
        day:     昼の動画URL (12:00-17:59 Tokyo time)
        night:   夜の動画URL (18:00-4:59 Tokyo time)
    -->
    <video class="hero-video" id="heroVideo" autoplay muted loop playsinline></video>
    <div class="hero-video-overlay"></div>
    <div class="hero-img-bg" id="heroImgBg"></div>

    <div class="grid-bg" aria-hidden="true"></div>
    <div class="particles" id="particles" aria-hidden="true"></div>

    <div class="hero-content">
      <div class="clock-badge">
        <div class="clock-dot"></div>
        Live from Tokyo — It's late somewhere
      </div>

      <h1>
        <span class="h1-line1">YOU'RE AWAKE</span>
        <span class="h1-line2">IN TOKYO</span>
        <span class="h1-line3">at 2am. Good.</span>
      </h1>

      <p class="hero-sub">
        Jet lag brought you here. Let us show you what Tokyo looks like when everyone else is asleep.
        Real venues. Real hours. Verified open.
      </p>

      <div id="visitorClock" style="margin-top:1.5rem; font-size:0.72rem; color:var(--text-dim); line-height:2; border-left: 2px solid rgba(191,0,255,0.4); padding-left:1rem;"></div>

      <div class="world-clock" id="worldClock" role="region" aria-label="World clock showing current times" aria-live="polite">
        <div class="clock-city">
          <div class="clock-city-name">🗼 Tokyo</div>
          <div class="clock-city-time tokyo" id="time-tokyo">--:--</div>
          <div class="clock-city-status status-awake" id="status-tokyo"></div>
        </div>
        <div class="clock-city">
          <div class="clock-city-name">🌁 Los Angeles</div>
          <div class="clock-city-time la" id="time-la">--:--</div>
          <div class="clock-city-status status-sleep" id="status-la"></div>
        </div>
        <div class="clock-city">
          <div class="clock-city-name">🗽 New York</div>
          <div class="clock-city-time nyc" id="time-nyc">--:--</div>
          <div class="clock-city-status status-sleep" id="status-nyc"></div>
        </div>
        <div class="clock-city">
          <div class="clock-city-name">🎡 London</div>
          <div class="clock-city-time london" id="time-london">--:--</div>
          <div class="clock-city-status status-sleep" id="status-london"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- WHY AWAKE -->
  <section id="why">
    <div class="section-label">// the science of suffering</div>
    <h2 class="section-title">Your Body <span>Has No Idea</span><br>Where It Is</h2>

    <div class="jetlag-grid">
      <div class="jetlag-card">
        <div class="jetlag-time">1AM</div>
        <div class="jetlag-from">If you flew from LA or SF</div>
        <div class="jetlag-feeling">Your body thinks it's 9AM. You're fully awake, slightly confused, and weirdly hungry. This is peak jet lag hour — the gap between Tokyo night and your California morning.</div>
        <div class="jetlag-action">→ Go for ramen. Walk Shinjuku.</div>
      </div>
      <div class="jetlag-card">
        <div class="jetlag-time">2AM</div>
        <div class="jetlag-from">If you flew from New York</div>
        <div class="jetlag-feeling">Your brain says it's 1PM. You're alert, functional, maybe even productive. The streets are quiet but the convenience stores are open and the vending machines are eternal.</div>
        <div class="jetlag-action">→ Konbini run. 7-Eleven onigiri.</div>
      </div>
      <div class="jetlag-card">
        <div class="jetlag-time">4AM</div>
        <div class="jetlag-from">If you flew from London or Europe</div>
        <div class="jetlag-feeling">It's noon back home. You're not tired at all and slightly smug about it. This is when Tokyo transforms — the delivery trucks appear, the fishermen head to Tsukiji, the city exhales.</div>
        <div class="jetlag-action">→ Catch sunrise at Ueno Park.</div>
      </div>
      <div class="jetlag-card">
        <div class="jetlag-time">5AM</div>
        <div class="jetlag-from">If you flew from the Middle East</div>
        <div class="jetlag-feeling">Your clock says 11AM. The first trains start running. Old men do radio calisthenics in the park. The city's secret morning shift begins, and you're the only tourist allowed to see it.</div>
        <div class="jetlag-action">→ Meiji Shrine before the crowds.</div>
      </div>
    </div>
  </section>

  <div class="neon-line" aria-hidden="true"></div>

  <!-- VENUES -->
  <section id="venues">
    <div class="section-label">// verified late-night venues by area</div>
    <h2 class="section-title">Where to Go<br><span>Right Now</span></h2>
    <p class="section-desc">
      All venues below are open late or 24 hours. Organized by Tokyo neighborhood so you can explore what's nearby. Hours verified but always confirm before you go.
    </p>

    <div class="area-nav-wrap" id="areaNavWrap"><nav class="area-nav" id="areaNav" role="toolbar" aria-label="Filter venues by area">
      <button class="area-btn active" data-area="all" aria-pressed="true">All Areas</button>
      <button class="area-btn" data-area="shinjuku" aria-pressed="false">Shinjuku</button>
      <button class="area-btn" data-area="shibuya" aria-pressed="false">Shibuya</button>
      <button class="area-btn" data-area="roppongi" aria-pressed="false">Roppongi</button>
      <button class="area-btn" data-area="harajuku" aria-pressed="false">Harajuku</button>
      <button class="area-btn" data-area="shimokitazawa" aria-pressed="false">Shimokitazawa</button>
      <button class="area-btn" data-area="nakameguro" aria-pressed="false">Nakameguro</button>
      <button class="area-btn" data-area="ebisu" aria-pressed="false">Ebisu</button>
      <button class="area-btn" data-area="ginza" aria-pressed="false">Ginza</button>
      <button class="area-btn" data-area="asakusa" aria-pressed="false">Asakusa</button>
    </nav></div>

    <!-- ═══════════ SHINJUKU ═══════════ -->
    <div class="area-section" id="area-shinjuku" role="region" aria-labelledby="heading-shinjuku">
      <div class="area-header">
        <div class="area-name" id="heading-shinjuku">Shinjuku</div>
        <div class="area-name-jp">新宿</div>
      </div>
      <div class="area-desc">Tokyo's neon-drenched epicenter that truly never sleeps. The east side is a labyrinth of entertainment — Golden Gai's 200+ micro-bars crammed into six narrow alleys, Kabukicho's towering entertainment complexes blazing with light, and 24-hour ramen joints steaming through the coldest nights. West Shinjuku's skyscraper district offers a completely different face: corporate towers with free observation decks and quiet parks tucked between glass monoliths. The station itself moves 3.5 million people daily — the busiest in the world. At 2AM, East Shinjuku is still alive; the drunk salarymen, the club-goers, the jet-lagged wanderers all converge here. This is ground zero for your sleepless Tokyo night.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1554797589-7241bb691973?w=600&h=360&fit=crop&crop=center" alt="Ramen bowl in Tokyo" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-ramen">Ramen</span>
            <div class="venue-name">Fuunji</div>
            <div class="venue-name-jp">風雲児 — Shinjuku South Exit</div>
            <div class="venue-hours">Mon–Sat 11AM–3PM, 5PM–9PM · Closed Sun</div>
            <div class="venue-desc">Tsukemen (dipping ramen) worth the queue. Rich, creamy chicken-and-seafood broth. Cash only, ticket machine. Tabelog TOKYO 100. Expect a line at lunch; evening is shorter wait.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku South Exit 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Order the <strong>tsukemen</strong> (dipping ramen) with extra-thick noodles. Add ajitama egg.</div>
            <div class="venue-verify">NOT open late — closes 9PM. Plan accordingly.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=風雲児+代々木+東京" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1557872943-16a5ac26437e?w=600&h=360&fit=crop&crop=center" alt="Late night ramen in Tokyo" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-ramen">Ramen · 24H</span>
            <div class="venue-name">Ichiran Shinjuku</div>
            <div class="venue-name-jp">一蘭 新宿中央東口店</div>
            <div class="venue-hours">Open 24 hours</div>
            <div class="venue-desc">Solo booths for the lone, jet-lagged diner. Order by form. No eye contact required. Consistent tonkotsu deeply comforting at 3AM. Ramen from ¥1,080.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku East Exit 2 min</span>
            </div>
            <div class="venue-recommend">🎯 Get the <strong>Classic Tonkotsu</strong> with extra-firm noodles (kata-men). Add extra chashu.</div>
            <div class="venue-verify">10% late-night surcharge 10PM–6AM</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=一蘭+新宿中央東口店" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1614563637806-1d0e645e0940?w=600&h=360&fit=crop&crop=center" alt="Niboshi ramen bowl" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-ramen">Ramen · 24H</span>
            <div class="venue-name">Nagi Golden Gai</div>
            <div class="venue-name-jp">すごい煮干ラーメン凪 新宿ゴールデン街</div>
            <div class="venue-hours">Open 24 hours (irregular holidays)</div>
            <div class="venue-desc">Niboshi (dried sardine) broth — 70+ grams per bowl. Steep staircase, ~10 bar stools. The 4AM bowl after bar hopping is a rite of passage. From ¥1,350.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku Sanchome 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Order the <strong>Sugoi Niboshi Ramen</strong> (intense sardine broth). Request extra niboshi powder on top.</div>
            <div class="venue-verify">Irregular holidays — check before going. Michelin listed.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=すごい煮干ラーメン凪+新宿ゴールデン街" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1577593980286-2fc63b35d575?w=600&h=360&fit=crop&crop=center" alt="Golden Gai alley in Shinjuku" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Golden Gai</div>
            <div class="venue-name-jp">新宿ゴールデン街</div>
            <div class="venue-hours">Most bars: 8PM–2AM · Some until 5AM</div>
            <div class="venue-desc">200+ tiny bars in six narrow alleys frozen in the 1970s. Some seat 5 people. Cover ¥500–1,000. Cash only at most spots. Look for English signs or open doors.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku Sanchome 2 min</span>
            </div>
            <div class="venue-recommend">🎯 Start at bars with English signs near 5th Avenue. Try <strong>Albatross</strong> or <strong>Death Match in Hell</strong>.</div>
            <div class="venue-verify">Most bars close by 2AM — don't assume 5AM</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Golden+Gai+Shinjuku+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1514933651103-005eec06c04b?w=600&h=360&fit=crop&crop=center" alt="Bar interior with warm lighting" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Albatross G</div>
            <div class="venue-name-jp">アルバトロス — Golden Gai 5th Ave</div>
            <div class="venue-hours">7PM–5AM most nights</div>
            <div class="venue-desc">Three-story bar with rickety spiral staircase and gothic chandeliers. Victorian-baroque in a Golden Gai building. English-speaking bartenders. Cover ~¥500.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku Sanchome 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Grab a seat on the <strong>third floor</strong> for the best chandelier views. Try the house whisky highball.</div>
            <div class="venue-verify">Weekday hours may vary</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Albatross+G+Golden+Gai+Shinjuku" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1542051841857-5f90071e7989?w=600&h=360&fit=crop&crop=center" alt="Kabukicho neon lights at night" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-walk">Walk</span>
            <div class="venue-name">Kabukicho</div>
            <div class="venue-name-jp">歌舞伎町</div>
            <div class="venue-hours">Never sleeps</div>
            <div class="venue-desc">Tokyo's entertainment district in full neon at 3AM. The Tokyu Kabukicho Tower dominates the skyline. Walk through for the spectacle — you don't need to spend money.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">✨</span> Free</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku East Exit 5 min</span>
            </div>
            <div class="venue-recommend">🎯 Walk past the <strong>Toho Cinema Godzilla</strong> head. Explore the Tokyu Kabukicho Tower rooftop area.</div>
            <div class="venue-verify">Avoid touts pretending to be bar staff — verify prices before sitting</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Kabukicho+Shinjuku+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1545569341-9eb8b30979d9?w=600&h=360&fit=crop&crop=center" alt="Japanese onsen hot spring" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-onsen">Onsen · 24H</span>
            <div class="venue-name">Thermae-Yu</div>
            <div class="venue-name-jp">テルマー湯 — Shinjuku</div>
            <div class="venue-hours">Open 24 hours</div>
            <div class="venue-desc">A proper onsen in central Shinjuku. Natural hot spring water from Izu. 6 indoor baths + open-air, stone sauna, restaurant. Weekday ¥2,700 / Weekend ¥2,800.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku Sanchome 5 min</span>
            </div>
            <div class="venue-recommend">🎯 Go for the <strong>rotenburo</strong> (outdoor bath) and try the stone sauna. Bring your own towel or rent one.</div>
            <div class="venue-verify">Late-night surcharge after 11PM: +¥2,000–2,300. Tattoo policy applies.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=テルマー湯+新宿" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1590559899731-a382839e5549?w=600&h=360&fit=crop&crop=center" alt="Japanese convenience store at night" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-24h">24H</span>
            <div class="venue-name">Don Quijote Shinjuku</div>
            <div class="venue-name-jp">ドン・キホーテ 新宿歌舞伎町店</div>
            <div class="venue-hours">Open 24 hours</div>
            <div class="venue-desc">The chaotic discount store is a sensory experience at 3AM. Snacks, souvenirs, electronics, costumes, and everything else across multiple floors. Tax-free shopping for tourists.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku East Exit 4 min</span>
            </div>
            <div class="venue-recommend">🎯 Head to <strong>B1 for snacks</strong>, 4F for electronics, and look for the tax-free counter on the ground floor.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=ドン・キホーテ+新宿歌舞伎町" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&h=360&fit=crop&crop=center" alt="Izakaya interior" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-izakaya">Izakaya</span>
            <div class="venue-name">Omoide Yokocho</div>
            <div class="venue-name-jp">思い出横丁 — Piss Alley</div>
            <div class="venue-hours">Most stalls: 5PM–midnight</div>
            <div class="venue-desc">Tiny yakitori stalls under the train tracks, west of the station. Smoke, beer, and grilled skewers in an alley that hasn't changed since the 1940s. Cash only.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku West Exit 1 min</span>
            </div>
            <div class="venue-recommend">🎯 Order <strong>yakitori</strong> (chicken skewers) and a draft beer. The negima (chicken + leek) is essential.</div>
            <div class="venue-verify">Most close by midnight — arrive by 10PM for best experience</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=思い出横丁+新宿" target="_blank">→ Google Maps</a>
          </div>
        </div>

      
        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1551632436-cbf8dd35adfa?w=600&h=360&fit=crop&crop=center" alt="Japanese whisky bar" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Zoetrope</div>
            <div class="venue-name-jp">ゾエトロープ — Shinjuku West</div>
            <div class="venue-hours">Mon–Sat 7PM–4AM</div>
            <div class="venue-desc">Over 300 Japanese whiskies in a cinematic setting. The owner is a film enthusiast — movie memorabilia covers every wall. Small, seats about 12. One of the best whisky bars in the world.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku West Exit 7 min</span>
            </div>
            <div class="venue-recommend">🎯 Ask the bartender to recommend a <strong>Japanese whisky flight</strong>. Try something from Chichibu or Mars distillery you cannot get outside Japan.</div>
            <div class="venue-verify">Can get full quickly — arrive before 9PM on weekends</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Zoetrope+Bar+Shinjuku+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=600&h=360&fit=crop&crop=center" alt="Late night Japanese curry" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-24h">24H · Curry</span>
            <div class="venue-name">Matsuya Shinjuku</div>
            <div class="venue-name-jp">松屋 新宿南口店</div>
            <div class="venue-hours">Open 24 hours</div>
            <div class="venue-desc">Japan's beloved gyudon (beef bowl) chain. Reliable, fast, cheap, and open around the clock. The curry set with miso soup is a 3AM lifesaver. Ticket machine ordering — no Japanese needed.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku South Exit 1 min</span>
            </div>
            <div class="venue-recommend">🎯 Order the <strong>premium gyudon set</strong> with miso soup and raw egg (¥580). Crack the egg over the rice — trust the process.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=松屋+新宿南口店" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1560807707-8cc77767d783?w=600&h=360&fit=crop&crop=center" alt="Robot restaurant Shinjuku" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Karaoke · 24H</span>
            <div class="venue-name">Karaoke Kan Shinjuku</div>
            <div class="venue-name-jp">カラオケ館 新宿大ガード店</div>
            <div class="venue-hours">Open 24 hours</div>
            <div class="venue-desc">Private karaoke rooms with English song selection. The go-to solution for 2-5AM when you have energy but nowhere else to put it. Cheap night packs include unlimited drinks.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shinjuku West Exit 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Book the <strong>free-time night plan</strong> (midnight-5AM, ~¥1,500 with drinks). English songs available — search by artist name.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=カラオケ館+新宿大ガード" target="_blank">→ Google Maps</a>
          </div>
        </div>
</div>
    </div>

    <!-- ═══════════ SHIBUYA ═══════════ -->
    <div class="area-section" id="area-shibuya" role="region" aria-labelledby="heading-shibuya">
      <div class="area-header">
        <div class="area-name" id="heading-shibuya">Shibuya</div>
        <div class="area-name-jp">渋谷</div>
      </div>
      <div class="area-desc">The famous scramble crossing is just the opening act. Behind the Hachiko statue and neon billboards lies a layered neighborhood: Center-gai's youth culture and fast fashion, Dogenzaka's nightclub row, the sophisticated boutiques of Shibuya Stream and Scramble Square, and quiet residential streets where local bars hide in plain sight. Weekend nights here buzz until dawn — DJs spin at WOMB and Sound Museum Vision while late-night diners fill every ramen shop. Weekday nights reveal a different Shibuya: the crossing empty save for traffic lights cycling through colors for nobody, the famous Tsutaya building glowing like a lighthouse. Since 2025, outdoor drinking is banned 6PM-5AM — the energy has moved indoors.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1532236204992-f5e85c024202?w=600&h=360&fit=crop&crop=center" alt="Shibuya crossing at night" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-walk">Walk</span>
            <div class="venue-name">Shibuya Crossing</div>
            <div class="venue-name-jp">渋谷スクランブル交差点</div>
            <div class="venue-hours">Always open · Trains stop ~1AM</div>
            <div class="venue-desc">Still buzzing at 2AM on weekends. Weekday nights: eerily beautiful, traffic lights changing for nobody. Best views from Shibuya Sky or Mag's Park rooftop (free).</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">✨</span> Free</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shibuya Hachiko Exit 1 min</span>
            </div>
            <div class="venue-recommend">🎯 Best view from <strong>Shibuya Sky</strong> (¥2,000) or free from Mag's Park rooftop above L'Occitane.</div>
            <div class="venue-verify">Alcohol ban 6PM–5AM since 2025 — no street drinking</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Shibuya+Scramble+Crossing+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=600&h=360&fit=crop&crop=center" alt="Dimly lit cocktail bar" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Bar Bossa</div>
            <div class="venue-name-jp">バール・ボッサ — Shibuya</div>
            <div class="venue-hours">6PM–2AM · Closed Sun</div>
            <div class="venue-desc">Intimate bossa nova bar tucked away in Shibuya's back streets. Vinyl collection on the walls, cocktails crafted with care. A mellow escape from the crossing's chaos.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shibuya 8 min</span>
            </div>
            <div class="venue-recommend">🎯 Order the <strong>caipirinha</strong> while listening to the vinyl bossa nova collection. Ask the bartender for recommendations.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Bar+Bossa+Shibuya+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1503899036084-c55cdd92da26?w=600&h=360&fit=crop&crop=center" alt="Tokyo night streets" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-club">Club</span>
            <div class="venue-name">WOMB</div>
            <div class="venue-name-jp">ウーム — Dogenzaka</div>
            <div class="venue-hours">Fri–Sat 11PM–5AM</div>
            <div class="venue-desc">One of Asia's most famous nightclubs. Four floors, world-class sound system, international and local DJs. Cover varies by event (¥2,000–4,000). ID required.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shibuya 7 min (Dogenzaka)</span>
            </div>
            <div class="venue-recommend">🎯 Check the <strong>event lineup</strong> online first. The main floor sound system is world-class. Bring ID (passport works).</div>
            <div class="venue-verify">Check event schedule — not open every night</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=WOMB+Shibuya+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1551218808-94e220e084d2?w=600&h=360&fit=crop&crop=center" alt="Ramen shop interior" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-ramen">Ramen · 24H</span>
            <div class="venue-name">Ichiran Shibuya</div>
            <div class="venue-name-jp">一蘭 渋谷店</div>
            <div class="venue-hours">Open 24 hours</div>
            <div class="venue-desc">Same solo-booth tonkotsu experience, steps from the crossing. Perfect post-club fuel at 4AM. The building is easy to spot with its red lantern facade.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shibuya Hachiko Exit 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Same quality as Shinjuku branch. <strong>Extra-firm noodles + extra garlic</strong> at 4AM hits different.</div>
            <div class="venue-verify">10% late-night surcharge 10PM–6AM</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=一蘭+渋谷店" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1480796927426-f609979314bd?w=600&h=360&fit=crop&crop=center" alt="Shibuya nightscape" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-24h">24H</span>
            <div class="venue-name">Shibuya Mega Don Quijote</div>
            <div class="venue-name-jp">MEGAドン・キホーテ 渋谷本店</div>
            <div class="venue-hours">Open 24 hours</div>
            <div class="venue-desc">Seven floors of organized chaos. Snacks, cosmetics, electronics, and bizarre novelty items. The kind of place you enter at 2AM and emerge at 4AM. Tax-free for tourists.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shibuya 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Cosmetics floor has Japan-exclusive brands. <strong>Kit Kat corner</strong> for souvenir flavors you cannot find elsewhere.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=MEGAドンキホーテ+渋谷本店" target="_blank">→ Google Maps</a>
          </div>
        </div>

      
        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1519671482749-fd09be7ccebf?w=600&h=360&fit=crop&crop=center" alt="Nightclub dance floor" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-club">Club</span>
            <div class="venue-name">Sound Museum Vision</div>
            <div class="venue-name-jp">サウンドミュージアム ヴィジョン</div>
            <div class="venue-hours">Fri–Sat 11PM–5AM</div>
            <div class="venue-desc">Multi-floor club with four distinct sound zones. Better sound system than WOMB, some say. International DJs and a more local crowd. The terrace is a great breather between sets.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shibuya 5 min (Dogenzaka)</span>
            </div>
            <div class="venue-recommend">🎯 Check <strong>RA (Resident Advisor)</strong> for tonight's lineup. The basement floor gets the best DJs.</div>
            <div class="venue-verify">Check event schedule — not open every night. ID required.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Sound+Museum+Vision+Shibuya" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&h=360&fit=crop&crop=center" alt="Modern Japanese restaurant" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-izakaya">Izakaya</span>
            <div class="venue-name">Uobei Shibuya</div>
            <div class="venue-name-jp">魚べい 渋谷道玄坂店</div>
            <div class="venue-hours">11AM–11PM</div>
            <div class="venue-desc">High-speed sushi delivery via three-tier express lane. Order on tablet, sushi arrives on a bullet train track. Fun, affordable, and surprisingly good quality for conveyor sushi.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shibuya 4 min</span>
            </div>
            <div class="venue-recommend">🎯 Order the <strong>salmon aburi</strong> (torched salmon) and the engawa. Watch the bullet train delivery — it never gets old.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=魚べい+渋谷道玄坂店" target="_blank">→ Google Maps</a>
          </div>
        </div>
</div>
    </div>

    <!-- ═══════════ ROPPONGI ═══════════ -->
    <div class="area-section" id="area-roppongi" role="region" aria-labelledby="heading-roppongi">
      <div class="area-header">
        <div class="area-name" id="heading-roppongi">Roppongi</div>
        <div class="area-name-jp">六本木</div>
      </div>
      <div class="area-desc">Tokyo's international nightlife district has two faces. Street level: clubs, late-night restaurants, and an energy that peaks around 2AM on weekends. The main crossing around Roppongi Hills is where it all concentrates. But Roppongi's second life is cultural — the Mori Art Museum (open until 10PM most nights), the National Art Center, and 21_21 Design Sight make this one of Tokyo's premier art neighborhoods. Side streets like Azabu-Juban hide world-class cocktail bars and tiny sushi counters. The area around Tokyo Tower adds a romantic, old-Tokyo counterpoint to the neon chaos. If you're up past midnight, Roppongi will meet you where you are.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1540959733332-eab4deabeeaf?w=600&h=360&fit=crop&crop=center" alt="Tokyo Tower at night" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-walk">Walk</span>
            <div class="venue-name">Tokyo Tower Night View</div>
            <div class="venue-name-jp">東京タワー</div>
            <div class="venue-hours">Main deck until 11PM</div>
            <div class="venue-desc">The iconic tower lit up against the night sky. Even if the observation deck closes at 11PM, the walk around Shiba Park offers stunning views of the illuminated structure.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Akabanebashi 5 min / Kamiyacho 7 min</span>
            </div>
            <div class="venue-recommend">🎯 Walk around <strong>Shiba Park</strong> for the best photo angles. The illumination changes seasonally.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Tokyo+Tower" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1525268323446-0505b6fe7778?w=600&h=360&fit=crop&crop=center" alt="Whisky bar with bottles" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Gonpachi Roppongi</div>
            <div class="venue-name-jp">権八 六本木</div>
            <div class="venue-hours">11:30AM–3:30AM daily</div>
            <div class="venue-desc">The restaurant that inspired the Kill Bill fight scene. Stunning traditional architecture across multiple floors. Yakitori, soba, and creative cocktails until late.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Roppongi 5 min</span>
            </div>
            <div class="venue-recommend">🎯 Sit at the <strong>main floor counter</strong> for the full Tarantino-set experience. Order the soba and yakitori combo.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=権八+六本木" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1571068316344-75bc76f77890?w=600&h=360&fit=crop&crop=center" alt="Modern bar interior" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Gen Yamamoto</div>
            <div class="venue-name-jp">ジェン ヤマモト — Azabu-Juban</div>
            <div class="venue-hours">3PM–11PM · Closed Sun & Mon</div>
            <div class="venue-desc">8-seat cocktail omakase with seasonal Japanese ingredients. No menu — the bartender reads you. A transcendent cocktail experience. Reservations essential.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Azabu-Juban 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Book the <strong>8-course omakase</strong> (¥6,600). Each cocktail uses a single seasonal Japanese fruit or vegetable.</div>
            <div class="venue-verify">Reservation only — book via website or phone</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Gen+Yamamoto+Azabu+Juban+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1598514983318-2f64f8f4796c?w=600&h=360&fit=crop&crop=center" alt="Japanese izakaya dining" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-ramen">Ramen</span>
            <div class="venue-name">Afuri Roppongi</div>
            <div class="venue-name-jp">AFURI 六本木店</div>
            <div class="venue-hours">11AM–5AM</div>
            <div class="venue-desc">Yuzu shio (citrus salt) ramen that's lighter and more refreshing than typical tonkotsu. Beautiful presentation. A perfect 3AM bowl when you want something not too heavy.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Roppongi 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Order the <strong>Yuzu Shio Ramen</strong> (citrus salt). Add the ajitama egg and bamboo shoots.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=AFURI+六本木" target="_blank">→ Google Maps</a>
          </div>
        </div>

      
        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=600&h=360&fit=crop&crop=center" alt="Modern cocktail bar" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar · Late</span>
            <div class="venue-name">Mado Lounge</div>
            <div class="venue-name-jp">マドラウンジ — Roppongi Hills 52F</div>
            <div class="venue-hours">Mon–Thu 6PM–1AM · Fri–Sat 6PM–3AM</div>
            <div class="venue-desc">Cocktails 250 meters above Tokyo at the Roppongi Hills Mori Tower. Floor-to-ceiling windows with panoramic city views. Not cheap, but the view is worth every yen. Smart casual dress code.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Roppongi 5 min (via Mori Tower)</span>
            </div>
            <div class="venue-recommend">🎯 Book a <strong>window seat at sunset</strong> for the transition from golden hour to city lights. The gin &amp; tonic with Japanese citrus is excellent.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Mado+Lounge+Roppongi+Hills" target="_blank">→ Google Maps</a>
          </div>
        </div>
</div>
    </div>

    <!-- ═══════════ HARAJUKU / OMOTESANDO ═══════════ -->
    <div class="area-section" id="area-harajuku" role="region" aria-labelledby="heading-harajuku">
      <div class="area-header">
        <div class="area-name" id="heading-harajuku">Harajuku &amp; Omotesando</div>
        <div class="area-name-jp">原宿・表参道</div>
      </div>
      <div class="area-desc">Fashion, counterculture, and quiet spirituality coexist in this unique neighborhood. Takeshita Street is a daytime spectacle of crepe shops and costume stores, but walk two blocks in any direction and you'll find Ura-Harajuku's designer boutiques, vintage stores, and independent cafes. The tree-lined boulevard of Omotesando — Tokyo's Champs-Elysees — connects it all with architectural masterpieces by Tadao Ando, Kengo Kuma, and Herzog &amp; de Meuron. And then there's Meiji Shrine: step through the massive torii gate into 170 acres of ancient forest, and the city vanishes completely. At dawn, before anyone arrives, this is one of Tokyo's most powerful experiences. The neighborhood sleeps early, but for the jet-lagged early riser, it's paradise.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1583416750470-965b2707b355?w=600&h=360&fit=crop&crop=center" alt="Meiji Shrine torii gate" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-walk">Walk</span>
            <div class="venue-name">Meiji Shrine at Dawn</div>
            <div class="venue-name-jp">明治神宮</div>
            <div class="venue-hours">Opens at sunrise (~5AM)</div>
            <div class="venue-desc">Enter the forest before anyone arrives. The massive torii gate, the gravel paths, the morning rituals. One of Tokyo's most spiritual experiences, and free.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">✨</span> Free</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Harajuku/Meiji-Jingumae 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Enter from the <strong>Harajuku (south) gate</strong>. Walk slowly through the forest. The main hall ceremony at dawn is mesmerizing.</div>
            <div class="venue-verify">Opens at sunrise, closes at sunset — seasonal hours</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Meiji+Shrine+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1528360983277-13d401cdc186?w=600&h=360&fit=crop&crop=center" alt="Modern Tokyo cafe" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-cafe">Cafe</span>
            <div class="venue-name">Omotesando Koffee</div>
            <div class="venue-name-jp">表参道コーヒー</div>
            <div class="venue-hours">10AM–6PM</div>
            <div class="venue-desc">Minimalist specialty coffee in a renovated Japanese house. The cortado is perfection. Small and easy to miss — look for the minimal signage on a side street.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Omotesando 5 min</span>
            </div>
            <div class="venue-recommend">🎯 Order the <strong>cortado</strong> and the signature kashi (Japanese-style baked sweet). Small and easy to miss — look for minimal signage.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Omotesando+Koffee+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1606567595334-d39972c85dbe?w=600&h=360&fit=crop&crop=center" alt="Japanese gyoza dumplings" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-izakaya">Izakaya</span>
            <div class="venue-name">Harajuku Gyoza-ro</div>
            <div class="venue-name-jp">原宿餃子楼</div>
            <div class="venue-hours">11:30AM–4:30AM</div>
            <div class="venue-desc">Gyoza and beer. That's it. The pan-fried dumplings are crispy and cheap, the boiled ones are juicy. Open until 4:30AM and always packed after midnight. Cash only.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Harajuku/Meiji-Jingumae 4 min</span>
            </div>
            <div class="venue-recommend">🎯 Get both: <strong>yaki-gyoza</strong> (pan-fried, crispy) and <strong>sui-gyoza</strong> (boiled, juicy). Add a cold beer.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=原宿餃子楼" target="_blank">→ Google Maps</a>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════════ SHIMOKITAZAWA ═══════════ -->
    <div class="area-section" id="area-shimokitazawa" role="region" aria-labelledby="heading-shimokitazawa">
      <div class="area-header">
        <div class="area-name" id="heading-shimokitazawa">Shimokitazawa</div>
        <div class="area-name-jp">下北沢</div>
      </div>
      <div class="area-desc">Tokyo's bohemian heart beats in narrow lanes lined with vintage shops, record stores, live music venues, and craft bars. Shimokitazawa — affectionately 'Shimokita' — is what happens when art students and musicians claim a neighborhood. The recently developed areas along the old Odakyu Line tracks — Bonus Track, Reload, and the Shimokita Ekiue complex — have added stylish modern spaces without killing the vintage soul. Second-hand clothing stores rival those in Brooklyn or Shoreditch. On any given night, three or four tiny live houses host indie rock, experimental jazz, or underground hip-hop. The bars here are cheap, friendly, and stay open late. If Shinjuku is Tokyo's volume knob turned to 11, Shimokita is the dive bar where the real musicians hang after their gigs.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1567521464027-f127ff144326?w=600&h=360&fit=crop&crop=center" alt="Japanese izakaya with lanterns" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Mother</div>
            <div class="venue-name-jp">マザー — Shimokitazawa</div>
            <div class="venue-hours">6PM–5AM</div>
            <div class="venue-desc">A beloved dive bar that draws musicians, artists, and night owls. Cheap drinks, friendly crowd, and a jukebox that somehow always plays the right song at 3AM.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shimokitazawa South Exit 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Order a <strong>cheap highball</strong>, feed the jukebox, and talk to whoever sits next to you. Legendary vibes.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Mother+Bar+Shimokitazawa+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1511920170033-f8396924c348?w=600&h=360&fit=crop&crop=center" alt="Live music venue" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-club">Live House</span>
            <div class="venue-name">Shelter</div>
            <div class="venue-name-jp">シェルター — B1F</div>
            <div class="venue-hours">Shows typically 7PM–11PM</div>
            <div class="venue-desc">Underground live house that's been hosting indie rock, punk, and experimental music since the '90s. Small, sweaty, and legendary. Check schedule for shows.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shimokitazawa North Exit 5 min</span>
            </div>
            <div class="venue-recommend">🎯 Check <strong>shelter-web.net</strong> for tonight's lineup. Standing only — arrive early for good sightlines.</div>
            <div class="venue-verify">Schedule varies — check website before going</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Shelter+Shimokitazawa+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=600&h=360&fit=crop&crop=center" alt="Cozy cafe interior" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-cafe">Cafe</span>
            <div class="venue-name">Bear Pond Espresso</div>
            <div class="venue-name-jp">ベアポンド エスプレッソ</div>
            <div class="venue-hours">11AM–5PM (varies)</div>
            <div class="venue-desc">Legendary espresso bar with an eccentric owner. The "Angel Stain" espresso is served only on certain days. Small, unique, and worth the pilgrimage for coffee lovers.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Shimokitazawa 4 min</span>
            </div>
            <div class="venue-recommend">🎯 If it is available, order the legendary <strong>Angel Stain espresso</strong>. Otherwise, the regular shot is still exceptional.</div>
            <div class="venue-verify">Hours unpredictable — may close early</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Bear+Pond+Espresso+Shimokitazawa" target="_blank">→ Google Maps</a>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════════ NAKAMEGURO ═══════════ -->
    <div class="area-section" id="area-nakameguro" role="region" aria-labelledby="heading-nakameguro">
      <div class="area-header">
        <div class="area-name" id="heading-nakameguro">Nakameguro</div>
        <div class="area-name-jp">中目黒</div>
      </div>
      <div class="area-desc">A stylish riverside neighborhood that's become one of Tokyo's most desirable addresses. The Meguro River — flanked by cherry trees that create a pink tunnel in spring — is the neighborhood's spine, lined with independent boutiques, wine bars, and design studios. This is where creative professionals live: architects, photographers, brand consultants. The vibe is quieter and more refined than Shibuya (just two stops away), with an emphasis on craft and curation. At night, the cafes and cocktail bars glow along the water. The Starbucks Reserve Roastery — Kengo Kuma's architectural showpiece — anchors the commercial stretch. For late-night visitors, Nakameguro's charm is in its calm: a riverside walk at 1AM, a last drink at a standing bar, the reflection of lights on water.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1522748906645-95d8adfd52c7?w=600&h=360&fit=crop&crop=center" alt="Cherry blossom tree-lined river" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-walk">Walk</span>
            <div class="venue-name">Meguro River Walk</div>
            <div class="venue-name-jp">目黒川沿い散策</div>
            <div class="venue-hours">Always accessible</div>
            <div class="venue-desc">Beautiful at any hour. In spring, the cherry blossoms form a tunnel over the river. At night, the cafes and boutiques glow. A peaceful late-night walk away from the chaos.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">✨</span> Free</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Nakameguro 1 min</span>
            </div>
            <div class="venue-recommend">🎯 Walk south from the station along the river. In <strong>cherry blossom season</strong> (late March-April), the tunnel of flowers is breathtaking.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Meguro+River+Nakameguro+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=600&h=360&fit=crop&crop=center" alt="Craft cocktail being made" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Another 8</div>
            <div class="venue-name-jp">アナザーエイト</div>
            <div class="venue-hours">6PM–2AM</div>
            <div class="venue-desc">Standing cocktail bar along the river. The bartenders craft seasonal cocktails using Japanese ingredients. Small, vibey, and popular with a stylish local crowd.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Nakameguro 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Try the <strong>seasonal fruit cocktail</strong> — it changes monthly. Standing only, but the riverside location is worth it.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Another+8+Nakameguro+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1569718212165-3a8278d5f624?w=600&h=360&fit=crop&crop=center" alt="Japanese curry rice" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-ramen">Ramen</span>
            <div class="venue-name">Afuri Nakameguro</div>
            <div class="venue-name-jp">AFURI 中目黒店</div>
            <div class="venue-hours">11AM–5AM</div>
            <div class="venue-desc">The original Afuri location. Yuzu shio ramen in a sleek, modern space. The lighter broth is perfect when you want ramen without the heavy tonkotsu hit. Open until 5AM.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Nakameguro 2 min</span>
            </div>
            <div class="venue-recommend">🎯 The original location. <strong>Yuzu Shio Ramen</strong> is the signature. Try the vegan option if you want something lighter.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=AFURI+中目黒" target="_blank">→ Google Maps</a>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════════ EBISU ═══════════ -->
    <div class="area-section" id="area-ebisu" role="region" aria-labelledby="heading-ebisu">
      <div class="area-header">
        <div class="area-name" id="heading-ebisu">Ebisu</div>
        <div class="area-name-jp">恵比寿</div>
      </div>
      <div class="area-desc">Named after the Japanese god of prosperity (and a beer), Ebisu is Tokyo's sophisticated dining and drinking neighborhood. The Ebisu Yokocho food hall — a retro alley of 20+ stalls under the tracks — is the social heart, packed and loud by 8PM. But the real treasures are scattered in the surrounding blocks: speakeasy cocktail bars (Bar Trench, Bar Tram), intimate sushi counters, and French-Japanese fusion restaurants that earn Michelin stars. Yebisu Garden Place adds department-store polish with its plaza, museum, and seasonal illuminations. More relaxed than Roppongi, more grown-up than Shibuya, Ebisu is where Tokyoites go when they want to eat and drink well without the tourist crowds.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1551632811-561732d1e306?w=600&h=360&fit=crop&crop=center" alt="Japanese food stalls" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-izakaya">Yokocho</span>
            <div class="venue-name">Ebisu Yokocho</div>
            <div class="venue-name-jp">恵比寿横丁</div>
            <div class="venue-hours">5PM–2AM (some stalls until 4AM)</div>
            <div class="venue-desc">A retro-styled food alley under the train tracks with 20+ small stalls. Yakitori, oden, gyoza, and beer in a lively communal atmosphere. The energy here at 10PM is unmatched.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Ebisu East Exit 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Start with <strong>yakitori</strong> at any stall, then hop to the next for gyoza. Finish with oden. Communal seating is half the fun.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=恵比寿横丁" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1470337458703-46ad1756a187?w=600&h=360&fit=crop&crop=center" alt="Cocktail glass with garnish" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Bar Trench</div>
            <div class="venue-name-jp">バー・トレンチ — Ebisu</div>
            <div class="venue-hours">6PM–2AM · Closed Sun</div>
            <div class="venue-desc">Speakeasy-style cocktail bar known for absinthe and original cocktails. Dark, atmospheric, with a bartender who takes craft seriously. No cover. Walk-ins welcome.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Ebisu 5 min</span>
            </div>
            <div class="venue-recommend">🎯 Ask for the <strong>absinthe service</strong> — it is theatrical and delicious. The house cocktails use Japanese botanicals.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Bar+Trench+Ebisu+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1576577834715-18f5e3a33b4d?w=600&h=360&fit=crop&crop=center" alt="Sushi bar counter" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-sushi">Sushi</span>
            <div class="venue-name">Ebisu Sushi No Midori</div>
            <div class="venue-name-jp">梅丘寿司の美登利 恵比寿店</div>
            <div class="venue-hours">11AM–10PM</div>
            <div class="venue-desc">High-quality sushi at reasonable prices. Known for generous portions and fresh fish. Always a queue but it moves fast. The omakase set is excellent value.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Ebisu 2 min</span>
            </div>
            <div class="venue-recommend">🎯 Go for the <strong>omakase lunch set</strong> (best value). The chu-toro (medium fatty tuna) here is exceptionally generous.</div>
            <div class="venue-verify">Expect 30-60 min wait at peak hours</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=美登利寿司+恵比寿" target="_blank">→ Google Maps</a>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════════ GINZA ═══════════ -->
    <div class="area-section" id="area-ginza" role="region" aria-labelledby="heading-ginza">
      <div class="area-header">
        <div class="area-name" id="heading-ginza">Ginza</div>
        <div class="area-name-jp">銀座</div>
      </div>
      <div class="area-desc">Tokyo's original luxury district, where department stores have stood since the Meiji era and a single piece of sushi can cost more than your hotel room. Ginza's daytime face is polished and expensive: Chuo-dori lined with flagship stores from Chanel to Uniqlo, the Kabuki-za theater, and galleries tucked into every building. But after the shops close at 8PM, Ginza transforms. The side streets — especially the narrow lanes between Ginza 6-chome and 8-chome — reveal hidden basement bars where master bartenders craft cocktails in near-silence. Ginza's cocktail culture is among the world's finest, rooted in precision and respect for the craft. At midnight, walking the empty Chuo-dori with its illuminated buildings feels like being inside a perfectly lit film set.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1553621042-f6e147245754?w=600&h=360&fit=crop&crop=center" alt="Elegant cocktail bar" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Star Bar Ginza</div>
            <div class="venue-name-jp">スタアバー 銀座</div>
            <div class="venue-hours">5PM–midnight · Closed Sun</div>
            <div class="venue-desc">One of Japan's most legendary cocktail bars. The bartenders here are masters — each cocktail is a quiet performance. Dress smart casual. Reservations recommended.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Ginza 5 min</span>
            </div>
            <div class="venue-recommend">🎯 Order a <strong>classic cocktail</strong> — the martini or sidecar. Watch the bartender work. Dress smart casual minimum.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Star+Bar+Ginza+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1579871494447-9811cf80d66c?w=600&h=360&fit=crop&crop=center" alt="Sushi omakase" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-sushi">Sushi</span>
            <div class="venue-name">Sushi Zanmai Ginza</div>
            <div class="venue-name-jp">すしざんまい 本店</div>
            <div class="venue-hours">Open 24 hours</div>
            <div class="venue-desc">The 24-hour sushi chain's flagship. Not the fanciest sushi in Ginza, but reliable quality at reasonable prices at any hour. The Tuna King's empire never closes.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Tsukiji 3 min / Ginza 8 min</span>
            </div>
            <div class="venue-recommend">🎯 The <strong>tuna trio plate</strong> (maguro 3-ten mori) is the best value. Open 24h — perfect for a 3AM sushi craving.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=すしざんまい+本店+銀座" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1523294587484-bae6cc870010?w=600&h=360&fit=crop&crop=center" alt="Ginza streets at night" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-walk">Walk</span>
            <div class="venue-name">Ginza Night Walk</div>
            <div class="venue-name-jp">銀座の夜散歩</div>
            <div class="venue-hours">Best after 10PM</div>
            <div class="venue-desc">Ginza empties out after the shops close. The luxury buildings become sculptures of light. Chuo-dori without traffic at midnight is a completely different city.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">✨</span> Free</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Ginza 0 min</span>
            </div>
            <div class="venue-recommend">🎯 Walk <strong>Chuo-dori</strong> from Ginza 4-chome to 8-chome after 10PM. The architecture becomes sculpture under night lighting.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Ginza+Chuo+Dori+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

      
        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1514933651103-005eec06c04b?w=600&h=360&fit=crop&crop=center" alt="Japanese whisky bar" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-bar">Bar</span>
            <div class="venue-name">Bar High Five</div>
            <div class="venue-name-jp">バー ハイファイブ — Ginza</div>
            <div class="venue-hours">6PM–midnight · Closed Sun & Hol</div>
            <div class="venue-desc">Regularly ranked among the world's best bars. Bartender Hidetsugu Ueno creates cocktails through conversation — no menu. Tell him what you feel like and he will craft perfection. Quiet, elegant, unforgettable.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Ginza 4 min</span>
            </div>
            <div class="venue-recommend">🎯 Just tell the bartender your <strong>mood and flavor preference</strong>. He will read you. No two visits are the same. Reservations strongly recommended.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Bar+High+Five+Ginza+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>
</div>
    </div>

    <!-- ═══════════ ASAKUSA ═══════════ -->
    <div class="area-section" id="area-asakusa" role="region" aria-labelledby="heading-asakusa">
      <div class="area-header">
        <div class="area-name" id="heading-asakusa">Asakusa &amp; Ueno</div>
        <div class="area-name-jp">浅草・上野</div>
      </div>
      <div class="area-desc">Old-world Tokyo lives here. Senso-ji — the city's oldest temple, founded in 628 AD — anchors a neighborhood that still feels like the shitamachi (downtown) of a century ago. The Kaminarimon gate, Nakamise-dori shopping street, and the five-story pagoda are iconic for good reason, but the real magic happens at the edges: Hoppy-dori's raucous outdoor izakayas where locals drink cheap and loud, the quiet streets along the Sumida River, and the views of Tokyo Skytree framed against traditional rooftops. Nearby Ueno adds world-class museums and a sprawling park with a pond, shrine, and zoo. For the jet-lagged night owl, Senso-ji's grounds are open 24 hours and dramatically lit — walking through the deserted temple complex at 3AM, with the pagoda glowing against the sky, is unforgettable.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1524413840807-0c3cb6fa808d?w=600&h=360&fit=crop&crop=center" alt="Senso-ji temple at night" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-walk">Walk</span>
            <div class="venue-name">Senso-ji at Night</div>
            <div class="venue-name-jp">浅草寺 夜の境内</div>
            <div class="venue-hours">Grounds open 24h · Main hall closes ~5PM</div>
            <div class="venue-desc">The temple grounds are open all night and dramatically lit. Walk through the Kaminarimon gate and Nakamise-dori with nobody around. One of Tokyo's most atmospheric experiences.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">✨</span> Free</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Asakusa 5 min</span>
            </div>
            <div class="venue-recommend">🎯 Walk through the <strong>Kaminarimon gate</strong> and down the empty Nakamise-dori. The five-story pagoda lit up at 3AM is unforgettable.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Sensoji+Temple+Asakusa+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1590736969955-71cc94901144?w=600&h=360&fit=crop&crop=center" alt="Japanese traditional street with lanterns" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-izakaya">Izakaya</span>
            <div class="venue-name">Hoppy-dori</div>
            <div class="venue-name-jp">ホッピー通り — Asakusa</div>
            <div class="venue-hours">Most stalls: 4PM–11PM</div>
            <div class="venue-desc">A lively alley of outdoor izakaya stalls. Locals drink Hoppy (a beer-like drink) and eat cheap yakitori. Rowdy, fun, and authentically shitamachi (downtown Tokyo).</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Asakusa 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Order <strong>Hoppy</strong> (the local beer-like drink) and beef stew (nikomi). Sit outside for the full experience.</div>
            <div class="venue-verify">Most close by 11PM — arrive early evening</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=ホッピー通り+浅草" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1490806843957-31f4c9a91c65?w=600&h=360&fit=crop&crop=center" alt="Ueno Park pond at dawn" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-walk">Walk</span>
            <div class="venue-name">Ueno Park at Dawn</div>
            <div class="venue-name-jp">上野公園 — 5AM</div>
            <div class="venue-hours">Park open 5AM–11PM · Best at sunrise</div>
            <div class="venue-desc">If you're still awake at 5AM, come here. Gates open at 5. Cherry blossom season or not, it's beautiful when empty. Morning exercisers, crows, and golden light on Shinobazu Pond.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">✨</span> Free</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Ueno 2 min</span>
            </div>
            <div class="venue-recommend">🎯 Enter from the main gate. Walk to <strong>Shinobazu Pond</strong> for lotus flowers (summer) and the best morning light.</div>
            <div class="venue-verify">NOT 24 hours — gates close 11PM, reopen 5AM</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Ueno+Park+Tokyo" target="_blank">→ Google Maps</a>
          </div>
        </div>

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1563245372-f21724e3856d?w=600&h=360&fit=crop&crop=center" alt="Tokyo Skytree at night" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-walk">View</span>
            <div class="venue-name">Skytree Night View</div>
            <div class="venue-name-jp">東京スカイツリー</div>
            <div class="venue-hours">Observation deck until 9PM (last entry 8PM)</div>
            <div class="venue-desc">Japan's tallest structure glows against the sky. Even after the deck closes, the view of the illuminated Skytree from along the Sumida River is spectacular. Walk the river at night.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Tokyo Skytree (Oshiage) 1 min</span>
            </div>
            <div class="venue-recommend">🎯 For the best free view, walk to the <strong>Sumida River west bank</strong> near Asakusa. The reflection in the water is spectacular.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=Tokyo+Skytree" target="_blank">→ Google Maps</a>
          </div>
        </div>

      
        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1545569341-9eb8b30979d9?w=600&h=360&fit=crop&crop=center" alt="Public bath house" loading="lazy" onerror="this.parentElement.style.display='none'">
            <div class="venue-img-overlay"></div>
          </div>
          <div class="venue-content">
            <span class="venue-tag tag-onsen">Sento</span>
            <div class="venue-name">Jakotsu-yu</div>
            <div class="venue-name-jp">蛇骨湯 — Asakusa</div>
            <div class="venue-hours">1PM–12AM (closed Tue)</div>
            <div class="venue-desc">One of Asakusa's last traditional sento (public baths). Natural hot spring water in a no-frills neighborhood bathhouse. Tattoo-friendly, foreigner-friendly, and deeply authentic Tokyo. Entry ¥520.</div>
            <div class="venue-meta">
              <span class="venue-meta-item venue-price"><span class="meta-icon">💰</span> ¥</span>
              <span class="venue-meta-item venue-station"><span class="meta-icon">🚶</span> Asakusa (Tsukuba Express) 3 min</span>
            </div>
            <div class="venue-recommend">🎯 Bring your own small towel or buy one there (¥200). The <strong>rotenburo (outdoor bath)</strong> is surprisingly serene for central Asakusa.</div>
            <div class="venue-verify">Closed Tuesdays. Check for irregular holidays.</div>
            <a class="venue-map-link" href="https://maps.google.com/?q=蛇骨湯+浅草" target="_blank">→ Google Maps</a>
          </div>
        </div>
</div>
    </div>

    <!-- Everywhere -->
    <div class="area-section" id="area-everywhere" style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(0,240,255,0.06);">
      <div class="area-header">
        <div class="area-name">Everywhere</div>
        <div class="area-name-jp">どこでも</div>
      </div>
      <div class="area-desc">These are the places you'll find on every block, in every neighborhood. Your 24-hour lifelines.</div>
      <div class="venues-grid">

        <div class="venue-card">
          <div class="venue-img-wrap">
            <img class="venue-img" src="https://images.unsplash.com/photo-1528731708534-816fe59f90cb?w=600&h=360&fit=crop&crop=center" alt="Japanese convenience store at night" loading="lazy" onerror="this.parentElement.style.display='none'">
